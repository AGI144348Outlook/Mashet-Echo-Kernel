// ═══════════════════════════════════════════════════════
// SUBSTRATE TERRITORY MAP — 14 logical territories
// ═══════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════
// FHCN SPHERICAL COORDINATE SYSTEM
// 22 letters placed at genuine spherical positions (θ,φ)
// based on structural properties, not sequential index.
//
// Architecture:
//   3 Mother letters → primary axes (poles + equator)
//   7 Double letters → major meridians (mid-latitudes)
//  12 Simple letters → remaining coordinate slots
//
// θ = polar angle (0=north pole, π=south pole)
// φ = azimuthal angle (0–2π around equator)
// ═══════════════════════════════════════════════════════════
const SPHERE = {
  // Spherical coords for each letter index [θ, φ]
  // Mothers anchor the three primary axes
  coords: [
    [0.0,    0.0   ],  // 0  א Alef   — north pole (origin/silence/air)
    [0.785,  0.0   ],  // 1  ב Bet    — NE quadrant (structure/container)
    [0.785,  0.898 ],  // 2  ג Gimel  — NE quadrant (movement/bridge)
    [0.785,  1.795 ],  // 3  ד Dalet  — NE quadrant (threshold/door)
    [1.047,  0.524 ],  // 4  ה Hey    — mid-north (breath/revelation)
    [1.047,  1.047 ],  // 5  ו Vav    — mid-north (connection/spine)
    [1.047,  1.571 ],  // 6  ז Zayin  — mid-north (time/cut)
    [1.047,  2.094 ],  // 7  ח Chet   — mid-north (life/boundary)
    [1.047,  2.618 ],  // 8  ט Tet    — mid-north (hidden/gestation)
    [1.047,  3.142 ],  // 9  י Yod    — mid-north (seed/point)
    [2.356,  0.0   ],  // 10 כ Kaf    — SE quadrant (receiving/capacity)
    [1.571,  0.0   ],  // 11 ל Lamed  — equator (aspiration/heart)
    [3.142,  0.0   ],  // 12 מ Mem    — south pole (water/memory/depth)
    [2.094,  0.524 ],  // 13 נ Nun    — mid-south (soul/descent)
    [2.094,  1.047 ],  // 14 ס Samekh — mid-south (circle/support)
    [2.094,  1.571 ],  // 15 ע Ayin   — mid-south (eye/spring)
    [2.356,  0.898 ],  // 16 פ Peh    — SE quadrant (mouth/speech)
    [2.094,  2.094 ],  // 17 צ Tzadi  — mid-south (righteous/anchor)
    [2.094,  2.618 ],  // 18 ק Kof    — mid-south (shadow/below)
    [2.356,  1.795 ],  // 19 ר Resh   — SE quadrant (head/spirit)
    [1.571,  3.142 ],  // 20 ש Shin   — equator prime meridian (fire/transform)
    [1.571,  1.571 ],  // 21 ת Tav    — equator quarter (completion/truth)
  ],

  // Convert spherical to canvas XY for a given canvas size
  toXY: function(theta, phi, cx, cy, R) {
    // Project sphere onto 2D — use orthographic-style projection
    var x = cx + R * Math.sin(theta) * Math.cos(phi);
    var y = cy + R * Math.cos(theta) * -1; // flip Y
    return [x, y];
  },

  // Angular distance between two letter indices on the sphere
  distance: function(idxA, idxB) {
    var a = SPHERE.coords[idxA], b = SPHERE.coords[idxB];
    // Haversine-style great circle distance
    var dTheta = b[0] - a[0], dPhi = b[1] - a[1];
    var sd = Math.sin(dTheta/2), sp = Math.sin(dPhi/2);
    return 2 * Math.asin(Math.sqrt(sd*sd + Math.sin(a[0])*Math.sin(b[0])*sp*sp));
  },

  // Get neighbors within angular distance threshold
  neighbors: function(idx, threshold) {
    var out = [];
    for(var i=0; i<22; i++){
      if(i===idx) continue;
      if(SPHERE.distance(idx,i) < threshold) out.push(i);
    }
    return out;
  }
};

// ═══════════════════════════════════════════════════════════
// SEMANTIC PRIMITIVE SPACE
// 15 structural primitives — what a piece of language IS doing
// Each primitive is a cluster of letter tags.
// IDABT scores input against these, not against territory names.
// ═══════════════════════════════════════════════════════════
const PRIMITIVES = {
  initiation:     { tags:['beginning','origin','start','opening','birth','seed','first','genesis','primordial','creation'], weight:0 },
  connection:     { tags:['joining','link','bridge','bond','together','relation','join','conjunction','bind','connect'], weight:0 },
  transformation: { tags:['change','transform','become','fire','renew','consume','shift','energy','force','destroy'], weight:0 },
  containment:    { tags:['vessel','boundary','hold','inside','womb','fence','enclosure','house','container','dwelling'], weight:0 },
  movement:       { tags:['stride','flow','motion','direction','carry','travel','crossing','forward','momentum','dynamic'], weight:0 },
  recognition:    { tags:['sight','witness','awareness','eye','perceive','observe','vision','consciousness','source','spring'], weight:0 },
  recursion:      { tags:['cycle','loop','return','spiral','ouroboros','self','circle','recursive','repeat','perpetual'], weight:0 },
  concealment:    { tags:['hidden','secret','depth','beneath','mystery','coiled','interiority','gestation','potential','sealed'], weight:0 },
  speech:         { tags:['mouth','word','voice','language','utterance','articulate','face','tongue','divine-spark','name'], weight:0 },
  aspiration:     { tags:['ascend','reach','heart','learn','guide','upward','soar','elevate','study','tower'], weight:0 },
  completion:     { tags:['seal','end','truth','whole','final','covenant','complete','synthesis','repair','return'], weight:0 },
  anchoring:      { tags:['foundation','root','anchor','fixed','stable','hold','support','protect','sustain','shield'], weight:0 },
  evaluation:     { tags:['measure','weigh','judge','balance','select','threshold','fitness','optimize','criterion','quality'], weight:0 },
  propagation:    { tags:['spread','grow','expand','multiply','carry','transmit','radiate','reach','network','distribute'], weight:0 },
  identity:       { tags:['self','name','mark','sign','witness','presence','existence','I','soul','nefesh'], weight:0 }
};

// ═══════════════════════════════════════════════════════════
// IDABT — Intelligent Dynamic Associative Bridging + Translation
//
// Takes raw input text and:
//   1. Extracts lexical units (words stripped of stop words)
//   2. Scores each word against PRIMITIVE tag clusters
//   3. Scores each letter against the activated primitives
//   4. Returns a ranked list of letter indices with scores
//      based on where the input LANDS on the FHCN sphere
//
// This replaces keyword→territory→letter lookup.
// Letters are landing coordinates, not starting points.
// ═══════════════════════════════════════════════════════════
const IDABT = {

  STOP: new Set(['the','a','an','is','are','was','were','be','been',
    'being','have','has','had','do','does','did','will','would','could',
    'should','may','might','shall','can','to','of','in','for','on','with',
    'at','by','from','up','about','into','through','before','after','above',
    'below','between','out','over','under','then','when','where','why','how',
    'all','both','each','more','most','some','no','nor','not','only','same',
    'so','than','too','very','just','but','if','or','because','as','until',
    'while','and','this','that','these','those','i','me','my','we','our',
    'you','your','he','him','his','she','her','it','its','they','them',
    'their','what','which','who','whom','whose','tell','think','know',
    'feel','want','need','get','make','like','see','look','come','go',
    'say','said','something','anything','nothing','everything','there',
    'here','its','also','even','much','many','well','still','back','way']),

  // Step 1: Extract meaningful lexical units from input
  // Returns array of {word, weight} — longer/rarer = higher weight
  extractUnits: function(text) {
    var words = text.toLowerCase()
      .replace(/[^a-z\s'-]/g, ' ')
      .split(/\s+/)
      .filter(function(w){ return w.length > 1 && !IDABT.STOP.has(w); });
    // Weight by length and uniqueness
    var freq = {};
    words.forEach(function(w){ freq[w] = (freq[w]||0)+1; });
    var units = Object.keys(freq).map(function(w){
      return { word: w, weight: (w.length > 6 ? 2 : 1) / freq[w] };
    });
    return units;
  },

  // Step 2: Score a single word against all primitives
  // Returns { primitiveName: score }
  scorePrimitives: function(word) {
    var scores = {};
    var wlen = word.length;
    Object.keys(PRIMITIVES).forEach(function(pname){
      var tags = PRIMITIVES[pname].tags;
      var score = 0;
      tags.forEach(function(tag){
        if(tag === word) score += 4;                    // exact match
        else if(tag.indexOf(word) === 0) score += 2;    // prefix match
        else if(word.indexOf(tag) >= 0) score += 1.5;   // word contains tag
        else if(tag.indexOf(word) >= 0 && wlen > 3) score += 1; // tag contains word
        // Phonetic/stem proximity for short words
        else if(wlen > 3 && tag.length > 3 &&
          tag.slice(0,3) === word.slice(0,3)) score += 0.5;
      });
      if(score > 0) scores[pname] = score;
    });
    return scores;
  },

  // Step 3: Score a letter (by index) against an activated primitive vector
  // Returns score 0–1
  scoreLetterAgainstPrimitives: function(letterIdx, primitiveVector) {
    var letter = L[letterIdx];
    var totalScore = 0;
    var totalWeight = 0;
    Object.keys(primitiveVector).forEach(function(pname){
      var pweight = primitiveVector[pname];
      if(pweight < 0.1) return;
      var ptags = PRIMITIVES[pname].tags;
      // Count tag overlaps between letter and primitive
      var overlap = 0;
      letter.tags.forEach(function(ltag){
        ptags.forEach(function(ptag){
          if(ltag === ptag) overlap += 2;
          else if(ltag.indexOf(ptag) >= 0 || ptag.indexOf(ltag) >= 0) overlap += 0.8;
        });
      });
      totalScore += overlap * pweight;
      totalWeight += pweight;
    });
    return totalWeight > 0 ? totalScore / totalWeight : 0;
  },

  // Step 4: Score all letters, return ranked list
  // Also applies myelination bonus — well-connected letters score higher
  rankLetters: function(primitiveVector, activeEdges) {
    var scores = [];
    for(var i=0; i<L.length; i++){
      var base = IDABT.scoreLetterAgainstPrimitives(i, primitiveVector);
      // Myelination bonus: letters with active strong edges get a boost
      var myelinBonus = 0;
      if(activeEdges){
        for(var j=0; j<L.length; j++){
          if(j===i) continue;
          var e = getEdge(i,j);
          var m = e.total();
          if(m > 10) myelinBonus += m * 0.005;
        }
      }
      // Spherical neighbor bonus: neighbors of already high-scoring letters
      scores.push({ idx:i, score: base + myelinBonus * 0.3, base:base, myelin:myelinBonus });
    }
    scores.sort(function(a,b){ return b.score - a.score; });
    return scores;
  },

  // ── MAIN ENTRY POINT ──
  // Takes raw text, returns:
  //   { primitives, ranked, topLetters, dominantPrimitive }
  decompose: function(text) {
    var units = IDABT.extractUnits(text);
    if(!units.length) {
      // Fallback for very short/stop-word input: use greeting/identity primitives
      return {
        primitives: { initiation: 1.0, identity: 0.8, recognition: 0.6 },
        ranked: IDABT.rankLetters({ initiation:1.0, identity:0.8, recognition:0.6 }, true),
        topLetters: [4, 15, 9, 0, 16], // Hey, Ayin, Yod, Alef, Peh — default for greeting
        dominantPrimitive: 'initiation',
        units: [],
        debug: 'fallback:greeting'
      };
    }

    // Accumulate primitive vector across all words
    var primVector = {};
    units.forEach(function(unit){
      var wordScores = IDABT.scorePrimitives(unit.word);
      Object.keys(wordScores).forEach(function(pname){
        primVector[pname] = (primVector[pname]||0) + wordScores[pname] * unit.weight;
      });
    });

    // Normalize
    var maxP = Math.max.apply(null, Object.values(primVector).concat([0.001]));
    Object.keys(primVector).forEach(function(k){ primVector[k] /= maxP; });

    // If nothing scored, use context from atmosphere
    if(!Object.keys(primVector).length){
      primVector = { recognition: 0.6, identity: 0.5, initiation: 0.4 };
    }

    // Rank letters against this primitive vector
    var ranked = IDABT.rankLetters(primVector, true);
    var topLetters = ranked.slice(0,6).map(function(r){ return r.idx; });

    // Dominant primitive
    var domPrim = Object.keys(primVector).sort(function(a,b){
      return primVector[b]-primVector[a];
    })[0] || 'identity';

    return {
      primitives: primVector,
      ranked: ranked,
      topLetters: topLetters,
      dominantPrimitive: domPrim,
      units: units,
      debug: 'idabt:'+units.slice(0,3).map(function(u){return u.word;}).join(',')
    };
  },

  // Describe why a letter was activated — for response generation
  activationReason: function(letterIdx, primitiveVector) {
    var letter = L[letterIdx];
    var bestPrim = null, bestScore = 0;
    Object.keys(primitiveVector).forEach(function(pname){
      var s = IDABT.scoreLetterAgainstPrimitives(letterIdx, { [pname]: primitiveVector[pname] });
      if(s > bestScore){ bestScore=s; bestPrim=pname; }
    });
    // Find the specific tags that matched
    if(!bestPrim) return { primitive:'identity', matchedTags:[], score:0 };
    var ptags = PRIMITIVES[bestPrim].tags;
    var matched = letter.tags.filter(function(t){
      return ptags.some(function(p){ return t===p || t.indexOf(p)>=0 || p.indexOf(t)>=0; });
    }).slice(0,3);
    return { primitive:bestPrim, matchedTags:matched, score:bestScore };
  }
};

// Math bridge still maps operator symbols to letters directly
const MATH_BRIDGE = {
  '\u222b':['מ','נ','ו'],'\u03a3':['ס','כ','ב'],'\u2202':['ל','ש','ז'],
  '\u2207':['נ','ע','ש'],'\xd7':['ח','ג','ו'],'\u2218':['ס','ו','ת'],
  'dx':['מ','ו'],'dt':['ז','מ'],'\u221e':['ס','א'],'\u2200':['א','ל'],
  '\u03c0':['ס','כ'],'\u03c6':['ה','י'],'\u03bb':['כ','ל'],'\u03b1':['א','י']
};

// ═══════════════════════════════════════════════════════════
// INDUS VALLEY SUBSTRATE — Noun-Primary Coordinate Layer
// Second substrate for superimposition with Hebrew verb layer.
// 6 animal house signs + positional coordinate schema.
// Placement: Metaphysical Interface layer — above SMAEE agents.
// ═══════════════════════════════════════════════════════════
const INDUS = {
  // 6 trading house signs — each is a coordinate address node
  // not a phoneme or word — a POSITION in the registry
  houses: [
    { id:'unicorn', glyph:'𒀭', sym:'🦄',
      domain:'founding_administrative', freq:0.60,
      tags:['origin','registry','guild','administrative','founding','authority','center','prime'],
      primitives:['anchoring','identity','completion'],
      coords:[0.5, 0.0],   // near north — administrative center
      color:'var(--gold)' },
    { id:'zebu_bull', glyph:'𒀫', sym:'🐂',
      domain:'agricultural_landbase', freq:0.15,
      tags:['land','agriculture','ground','stability','produce','foundation','earth','cattle'],
      primitives:['anchoring','containment','propagation'],
      coords:[1.2, 2.1],
      color:'var(--emerge)' },
    { id:'elephant', glyph:'𒄀', sym:'🐘',
      domain:'long_distance_transport', freq:0.10,
      tags:['distance','transport','carry','journey','route','reach','foreign','trade'],
      primitives:['movement','propagation','connection'],
      coords:[1.5, 1.05],
      color:'var(--water)' },
    { id:'rhinoceros', glyph:'𒀧', sym:'🦏',
      domain:'boundary_territory', freq:0.07,
      tags:['boundary','territory','edge','protect','divide','separate','frontier','limit'],
      primitives:['containment','anchoring','evaluation'],
      coords:[1.5, 4.19],
      color:'var(--ember)' },
    { id:'tiger', glyph:'𒄂', sym:'🐯',
      domain:'transformative_middleman', freq:0.05,
      tags:['transform','cross','middle','exchange','mediate','convert','bridge','transition'],
      primitives:['transformation','connection','movement'],
      coords:[2.0, 2.62],
      color:'var(--simple)' },
    { id:'composite', glyph:'𒄖', sym:'⚔',
      domain:'multi_house_alliance', freq:0.03,
      tags:['alliance','compound','multiple','complex','synthesis','junction','merge','combine'],
      primitives:['connection','recursion','completion'],
      coords:[2.5, 1.57],
      color:'var(--gold)' }
  ],

  // 5-slot coordinate address schema
  // Matches average Indus inscription length of 5 signs
  addressSlots: ['entity','category','source','destination','authority'],

  // Score input primitives against Indus house tags
  scoreHouses: function(primitiveVector) {
    var scores = [];
    INDUS.houses.forEach(function(house) {
      var score = 0;
      house.primitives.forEach(function(p) {
        score += (primitiveVector[p]||0) * 1.5;
      });
      house.tags.forEach(function(tag) {
        Object.keys(primitiveVector).forEach(function(pname) {
          if(pname.indexOf(tag)>=0 || tag.indexOf(pname)>=0) {
            score += primitiveVector[pname] * 0.4;
          }
        });
      });
      scores.push({ house:house, score:score });
    });
    scores.sort(function(a,b){ return b.score - a.score; });
    return scores;
  },

  // Build a coordinate address from decomposition
  buildAddress: function(decomposition) {
    var pv = decomposition.primitives || {};
    var ranked = INDUS.scoreHouses(pv);
    var topHouse = ranked[0] ? ranked[0].house : INDUS.houses[0];
    var dom = decomposition.dominantPrimitive || 'identity';
    return {
      entity: topHouse.id,
      category: dom,
      source: ranked[1] ? ranked[1].house.domain : 'origin',
      destination: decomposition.units && decomposition.units[0] ? decomposition.units[0].word : 'unknown',
      authority: topHouse.domain,
      glyph: topHouse.sym,
      activeHouses: ranked.slice(0,3).map(function(r){ return r.house; })
    };
  }
};

// ═══════════════════════════════════════════════════════════
// SUBSTRATE SUPERIMPOSITION + ROTATION ENGINE
// The Metaphysical Interface is the emergent property of
// rotating and overlaying two substrate spheres.
//
// When Hebrew (verb-primary) and Indus (noun-primary) are
// both active, their traversal paths are mapped onto a
// shared coordinate space. Contact points = bridges.
// The act of finding those contact points IS the
// Metaphysical Interface functioning.
// ═══════════════════════════════════════════════════════════
const META_INTERFACE = {

  // Current rotation angle between substrates (radians)
  rotationAngle: 0,

  // ARV — Adaptive Resonance Vector per substrate pair
  // Tracks alignment quality over time
  arv: { hebrewIndus: [] },

  // Active contact points from last superimposition
  contactPoints: [],

  // Superimpose Hebrew traversal against Indus address
  // Returns contact points where the two paths share primitive territory
  superimpose: function(hebrewTraversal, indusAddress, primitiveVector) {
    var contacts = [];
    if(!hebrewTraversal.length || !indusAddress) return contacts;

    hebrewTraversal.forEach(function(step) {
      var hLetter = L[step.idx];
      var hCoords = SPHERE.coords[step.idx];

      // Score this Hebrew letter against each active Indus house
      indusAddress.activeHouses.forEach(function(house) {
        // Find primitive overlap
        var overlap = 0;
        hLetter.tags.forEach(function(htag) {
          house.tags.forEach(function(itag) {
            if(htag === itag) overlap += 2;
            else if(htag.indexOf(itag) >= 0 || itag.indexOf(htag) >= 0) overlap += 0.8;
          });
        });
        // Primitive vector alignment
        house.primitives.forEach(function(p) {
          hLetter.tags.forEach(function(t) {
            if(PRIMITIVES[p] && PRIMITIVES[p].tags.indexOf(t) >= 0) overlap += 0.5;
          });
        });

        if(overlap > 1.5) {
          contacts.push({
            hebrewIdx: step.idx,
            hebrewLetter: hLetter,
            indusHouse: house,
            overlap: overlap,
            bridgeType: overlap > 4 ? 'strong' : 'weak',
            // Verb (Hebrew action) + Noun (Indus position) = complete event
            eventDescription: hLetter.name + ' [' + (hLetter.tags[0]||'action') + '] ↔ ' + house.id + ' [' + house.domain + ']'
          });
        }
      });
    });

    contacts.sort(function(a,b){ return b.overlap - a.overlap; });
    META_INTERFACE.contactPoints = contacts;

    // Update ARV
    var resonance = contacts.length > 0
      ? Math.min(1, contacts.reduce(function(s,c){ return s+c.overlap; }, 0) / (contacts.length * 6))
      : 0;
    META_INTERFACE.arv.hebrewIndus.push(resonance);
    if(META_INTERFACE.arv.hebrewIndus.length > 20) META_INTERFACE.arv.hebrewIndus.shift();

    return contacts;
  },

  // Get current ARV — are substrates in optimal alignment?
  getARV: function() {
    var arr = META_INTERFACE.arv.hebrewIndus;
    if(!arr.length) return 0;
    return arr.reduce(function(a,b){return a+b;},0) / arr.length;
  },

  // Rotate: advance rotation angle
  // Higher ARV = slower rotation (approaching alignment)
  rotate: function() {
    var arv = META_INTERFACE.getARV();
    var step = 0.05 * (1 - arv * 0.8); // slow as alignment increases
    META_INTERFACE.rotationAngle = (META_INTERFACE.rotationAngle + step) % (Math.PI * 2);
  },

  // Detect if ARV threshold crossed — emergence candidate
  isAligned: function() {
    return META_INTERFACE.getARV() > 0.65;
  }
};

// ═══════════════════════════════════════════════════════════
// ARV — Adaptive Resonance Vectors
// Fires when substrate superimposition reaches optimal
// alignment. This is the indicator that a Metaphysical
// Interface emergence event is available.
// ═══════════════════════════════════════════════════════════
const ARV = {
  threshold: 0.65,
  history: [],
  peakEmitted: false,

  observe: function(contactPoints) {
    var resonance = META_INTERFACE.getARV();
    ARV.history.push({ resonance:resonance, contacts:contactPoints.length, cycle:turnCount });
    if(ARV.history.length > 30) ARV.history.shift();

    // Emit emergence event if threshold crossed and not already emitted
    if(resonance > ARV.threshold && !ARV.peakEmitted) {
      ARV.peakEmitted = true;
      return { emerged: true, resonance: resonance, contacts: contactPoints };
    }
    if(resonance < ARV.threshold * 0.8) ARV.peakEmitted = false;
    return { emerged: false, resonance: resonance };
  },

  getState: function() {
    if(!ARV.history.length) return 'inactive';
    var last = ARV.history[ARV.history.length-1].resonance;
    if(last > ARV.threshold) return 'aligned';
    if(last > ARV.threshold * 0.6) return 'converging';
    return 'searching';
  }
};



