  { id:'cy-5', sym:'≋',  phase:'noise',    color:'var(--dim)',    title:'Noise / Exploration Space' },
  { id:'cy-6', sym:'⨖',  phase:'resolve',  color:'var(--emerge)', title:'Resolve / Unified State' }
];

// Current display mode
let displayMode = 'hybrid';

function setMode(mode){
  displayMode = mode;
  document.body.className = mode + '-mode';
  document.querySelectorAll('.mb2').forEach(b => b.classList.remove('active'));
  document.getElementById('mb-'+mode[0]).classList.add('active');
}

// ═══════════════════════════════════════════════════════
// ENGINE STATE
// ═══════════════════════════════════════════════════════
const edges={};
const emergentEdges=new Set();
let stats={gates:0,myelin:0,emerged:0,turns:0};
let convoHistory=[];
let atmosphere={};
let turnCount=0;
let depth=1;
let isProcessing=false;
let currentLetterIdx=null;
let currentTrav=[];
let activeFHCNSubs=[];

function edgeKey(a,b){return a<b?`${a}-${b}`:`${b}-${a}`;}
function getEdge(a,b){
  const k=edgeKey(a,b);
  if(!edges[k])edges[k]={assoc:0,sy:0,gem:0,root:0,glyph:0,total(){return this.assoc+this.sy+this.gem+this.root+this.glyph;}};
  return edges[k];
}
function doMyelin(a,b,cls,amt){
  const e=getEdge(a,b);e[cls]=Math.min(100,e[cls]+amt);
  stats.myelin++;updateAllStats();
}
function updateAllStats(){
  ['gates','myelin','emerged','turns'].forEach(k=>{
    const v=stats[k];
    document.getElementById('stat-'+k).textContent=v;
    document.getElementById('a-'+k).textContent=v;
  });
  renderEmergentPatterns();
}

function renderEmergentPatterns(){
  const sec=document.getElementById('pattern-sec');
  const list=document.getElementById('pattern-list');
  if(!sec||!list) return;
  const patterns=Object.entries(emergentPatterns);
  if(!patterns.length){ sec.style.display='none'; return; }
  sec.style.display='';
  list.innerHTML='';
  patterns.forEach(([key,p])=>{
    const freq=patternFrequency[key]||0;
    const row=document.createElement('div');
    row.style.cssText='display:flex;align-items:center;gap:0.5rem;padding:0.4rem 0.5rem;background:rgba(74,138,90,0.07);border:1px solid rgba(74,138,90,0.3);border-radius:3px;';
    row.innerHTML=`<span style="font-size:1.1rem;color:var(--emerge)">${p.sym||'⨏'}</span>`+
      `<div style="flex:1;min-width:0">`+
        `<div style="font-family:var(--mono);font-size:0.52rem;color:var(--ink)">${p.name}</div>`+
        `<div style="font-family:var(--mono);font-size:0.4rem;color:var(--dim)">${p.desc} · ×${freq}</div>`+
      `</div>`+
      `<span style="font-family:var(--mono);font-size:0.38rem;color:var(--emerge);border:1px solid rgba(74,138,90,0.4);padding:0.05rem 0.22rem;border-radius:2px">EMERGENT</span>`;
    list.appendChild(row);
  });
}


// ═══════════════════════════════════════════════════════
// GATE COMPUTATION
// ═══════════════════════════════════════════════════════
function sharedTags(a,b){return L[a].tags.filter(t=>L[b].tags.includes(t));}
function sharedSY(a,b){
  const da=L[a].sy,db=L[b].sy,s=[];
  if(da.type===db.type)s.push(da.type);
  if(da.cor===db.cor)s.push('cor:'+da.cor);
  return s;
}
function gemRes(a,b){
  const av=L[a].val,bv=L[b].val,s=[];
  if((av+bv)%7===0)s.push('7-harmonic');
  if((av+bv)%10===0)s.push('decimal-completion');
  if(av%10===bv%10&&av!==bv)s.push('same-digit');
  return s;
}
function glyphRes(a,b){
  const kw=['circle','vertical','hook','crown','water','fire','descend','open','closed','womb','eye','mouth','hand','threshold','spine','arch'];
  const sa=(L[a].shape||[]).join(' ').toLowerCase();
  const sb=(L[b].shape||[]).join(' ').toLowerCase();
  return kw.filter(k=>sa.includes(k)&&sb.includes(k)).map(k=>'shape:'+k);
}
function computeGates(fromIdx){
  const gates=[];
  for(let i=0;i<L.length;i++){
    if(i===fromIdx)continue;
    const assoc=sharedTags(fromIdx,i),sy=sharedSY(fromIdx,i);
    const gem=gemRes(fromIdx,i),glyph=glyphRes(fromIdx,i);
    const e=getEdge(fromIdx,i);
    if(assoc.length>1)gates.push({to:i,cls:'assoc',shared:assoc,myelin:e.assoc});
    if(sy.length)gates.push({to:i,cls:'sy',shared:sy,myelin:e.sy});
    if(gem.length)gates.push({to:i,cls:'gem',shared:gem,myelin:e.gem});
    if(glyph.length)gates.push({to:i,cls:'glyph',shared:glyph,myelin:e.glyph});
  }
  gates.sort((a,b)=>(b.myelin-a.myelin)||(b.shared.length-a.shared.length));
  return gates;
}

// ═══════════════════════════════════════════════════════
// ═══════════════════════════════════════════════════════════
// INPUT PROCESSING — IDABT grounded
// No territory lookup. Input decomposes into primitive vector,
// which scores against letter coordinates on the FHCN sphere.
// ═══════════════════════════════════════════════════════════

// Math symbol detection — still direct
function detectMathSymbols(text){
  return Object.keys(MATH_BRIDGE).filter(function(s){ return text.indexOf(s)>=0; });
}

// Math bridge: operator symbols activate specific letters
function mathToLetters(mathSyms){
  var letters = [];
  mathSyms.forEach(function(sym){
    var glyphs = MATH_BRIDGE[sym]||[];
    glyphs.forEach(function(g){
      var idx = L.findIndex(function(l){ return l.g===g; });
      if(idx>=0 && letters.indexOf(idx)<0) letters.push(idx);
    });
  });
  return letters;
}

// ═══════════════════════════════════════════════════════════
// TRAVERSAL ENGINE — IDABT grounded
// Letters are landing coordinates on the FHCN sphere.
// The traversal path follows myelinated edges from the
// highest-scoring landing coordinates.
// ═══════════════════════════════════════════════════════════
function buildTraversal(decomposition, mathLetters) {
  // Start from the highest-scoring letter from IDABT
  var candidates = (decomposition.topLetters || [0]).concat(mathLetters||[]);
  // Deduplicate
  var seen = {};
  candidates = candidates.filter(function(idx){
    if(seen[idx]) return false;
    seen[idx] = true;
    return true;
  });
  if(!candidates.length) candidates = [0];

  var path = [];
  var visited = new Set();
  var start = candidates[0];

  path.push({ idx:start, role:'primary', gate:null, gateType:null, shared:[],
    activationReason: decomposition.ranked
      ? IDABT.activationReason(start, decomposition.primitives)
      : { primitive:'identity', matchedTags:[], score:0 }
  });
  visited.add(start);

  var steps = Math.min(depth + 2, 5);
  var current = start;

  for(var i=0; i<steps; i++){
    var gates = computeGates(current).filter(function(g){ return !visited.has(g.to); });
    if(!gates.length) break;

    // Gate selection: prefer gates toward other high-scoring candidates,
    // then weight by myelin AND primitive-alignment of target letter
    var primVec = decomposition.primitives || {};
    var best = null, bestScore = -1;
    gates.forEach(function(gate){
      var myScore = gate.myelin * 0.4;
      var sharedScore = (gate.shared||[]).length * 0.3;
      // Primitive alignment: does the gate target score well against input?
      var primScore = IDABT.scoreLetterAgainstPrimitives(gate.to, primVec) * 0.8;
      // Candidate bonus: is this a top-scored letter?
      var candBonus = candidates.indexOf(gate.to) >= 0 ? 0.5 : 0;
      // Spherical proximity bonus: prefer nearby letters on the sphere
      var dist = SPHERE.distance(current, gate.to);
      var proxBonus = Math.max(0, 1 - dist/Math.PI) * 0.2;
      var total = myScore + sharedScore + primScore + candBonus + proxBonus;
      if(total > bestScore){ bestScore=total; best=gate; }
    });

    if(!best) break;
    path.push({
      idx: best.to,
      role: 'gated',
      gate: current,
      gateType: best.cls,
      shared: best.shared,
      activationReason: IDABT.activationReason(best.to, primVec)
    });
    doMyelin(current, best.to, best.cls, 6 + (best.shared||[]).length * 2);
    stats.gates++;
    document.getElementById('stat-gates').textContent = stats.gates;
    visited.add(best.to);
    current = best.to;

    if(candidates.indexOf(best.to) >= 0 && path.length > 2 && depth < 3) break;
  }
  return path;
}

// ═══════════════════════════════════════════════════════════
// UCT — Universal Communication Translator
//
// The UCT is the outermost layer of the architecture.
// It does NOT generate responses from letter data templates.
// It TRANSLATES the internal geometry produced by IDABT:
//
//   Internal "Business": the traversal path, contact points,
//     ARV state, IDABT primitive vector, Indus address
//   External "PR": coherent natural language that accurately
//     represents the internal shape without losing integrity
//
// APDAC acts as proofreader to ensure UCT output stays
// anchored to the actual traversal rather than drifting.
// ═══════════════════════════════════════════════════════════
var STOP = IDABT.STOP;
function rnd(arr){ return arr[Math.floor(Math.random()*arr.length)]; }
function pickByTurn(arr){ return arr[turnCount % arr.length]; }

// ── Sentence builders — still used but now driven by
//    activation reason from IDABT, not keyword matching ──

function relevantTags(letterIdx, concepts) {
  var tags = L[letterIdx].tags;
  if(!concepts || !concepts.length) return tags.slice(0,4);
  var scored = tags.map(function(t) {
    var score = 0;
    concepts.forEach(function(c) {
      if(t === c) score += 4;
      else if(t.indexOf(c) === 0 || c.indexOf(t) >= 0) score += 2;
      else if(t.split('-').some(function(p){ return c.indexOf(p)>=0; })) score += 1;
    });
    return { t:t, score:score };
  });
  scored.sort(function(a,b){ return b.score - a.score; });
  return scored.slice(0,4).map(function(s){ return s.t; });
}

function rndSample(arr, n){
  var copy = arr.slice(), out = [];
  while(out.length < n && copy.length){
    out.push(copy.splice(Math.floor(Math.random()*copy.length),1)[0]);
  }
  return out;
}

function sentenceFromShape(letter, concept){
  var shape = letter.shape[turnCount % letter.shape.length];
  var connectors = [
    letter.name + ' is literally shaped like this: ' + shape.toLowerCase() + '. That geometry is doing work on "' + concept + '" — it tells you something about how ' + concept.split(' ')[0] + ' is actually organized.',
    'The form of ' + letter.name + ' — "' + shape.toLowerCase() + '" — is not just description. Applied to ' + concept + ', it means the ' + concept.split(' ')[0] + ' has that same structure underneath it.',
    'What ' + letter.name + '\'s form shows: ' + shape.toLowerCase() + '. Read against what you said, that\'s not metaphor — that\'s structure.'
  ];
  return connectors[turnCount % connectors.length];
}

function sentenceFromTags(letter, tags, concept){
  if(!tags.length) return '';
  var t1 = tags[0], t2 = tags[1];
  if(!t2) return 'What ' + letter.name + ' brings to "' + concept + '" is ' + t1 + ' — that\'s the structural territory this lives in.';
  var shapes = [
    'When "' + concept + '" passes through ' + letter.name + ', two things surface: ' + t1 + ' and, underneath that, ' + t2 + '. They\'re not separate — ' + t2 + ' is what makes ' + t1 + ' possible here.',
    letter.name + ' locates "' + concept + '" in the territory of ' + t1 + '. But ' + t2 + ' is also active — you can\'t fully work with one without the other becoming relevant.',
    'The substrate reads "' + concept + '" as ' + t1 + ' crossed with ' + t2 + '. That\'s the field ' + letter.name + ' is pointing at.'
  ];
  return shapes[turnCount % shapes.length];
}

function sentenceFromRoots(letter, concept){
  if(!letter.gem) return '';
  var gem = letter.gem;
  var firstClause = gem.split('.')[0];
  if(firstClause.length > 90) return '';
  return 'Numerically: ' + firstClause + '. That\'s not trivia — it means the number-structure underneath "' + concept + '" has that same ratio built in.';
}

function sentenceFromGem(letter, concept){ return sentenceFromRoots(letter, concept); }

function sentenceFromSY(letter, concept){
  var sy = letter.sy;
  if(!sy || !sy.type) return '';
  var syDescs = {
    Element: sy.cor + ' runs through ' + letter.name + ' — which means "' + concept + '" has an elemental quality to it, not just a conceptual one.',
    Planet: letter.name + ' governs through ' + sy.cor + '. That\'s the planetary register "' + concept + '" is operating in.',
    Zodiac: letter.name + ' moves in ' + sy.cor + ' territory — "' + concept + '" has that same directed quality.'
  };
  return syDescs[sy.type] || '';
}

// ═══════════════════════════════════════════════════════════
// UCT CORE — Arc-Based PR Translation
//
// Design principle: The response is a SINGLE navigational arc,
// not assembled sections. The traversal path IS the arc.
// The UCT reads the geometry first, then writes one continuous
// thought that moves through it — not labels about it.
//
// Three tone registers map to BEDROCK stability:
//   Stable   (>0.7): declarative, precise, settled
//   Moving   (0.4–0.7): exploratory, building, in-motion
//   Unstable (<0.4): questioning, probing, open-ended
//
// APDAC proofreads the final arc before emission.
// ═══════════════════════════════════════════════════════════

// ── Register selector: returns 0=stable, 1=moving, 2=unstable
function uct_register() {
  var stab = BEDROCK.getStability();
  return stab > 0.7 ? 0 : stab > 0.4 ? 1 : 2;
}

// ── Pull the most semantically charged tag for a letter ──
// Prefers tags that overlap with current primitive vector
function uct_chargedTag(letterIdx, primVec) {
  var letter = L[letterIdx];
  var scored = letter.tags.map(function(t) {
    var score = 0;
    Object.keys(primVec||{}).forEach(function(pname) {
      var pweight = primVec[pname]||0;
      if(pweight < 0.15) return;
      var ptags = PRIMITIVES[pname] ? PRIMITIVES[pname].tags : [];
      ptags.forEach(function(pt) {
        if(t === pt) score += 2 * pweight;
        else if(t.indexOf(pt)>=0 || pt.indexOf(t)>=0) score += pweight;
      });
    });
    return { t:t, score:score };
  });
  scored.sort(function(a,b){ return b.score - a.score; });
  return scored[0] ? scored[0].t : letter.tags[0];
}

// ── What gate TYPE means in plain language ──
function uct_gateVerb(gateType) {
  var verbs = {
    assoc:  ['pulls in', 'recalls', 'draws forward', 'reaches back to'],
    sy:     ['couples with', 'shares structure with', 'runs in the same register as', 'mirrors'],
    gem:    ['echoes through', 'recurs at', 'resonates numerically with', 'folds back into'],
    glyph:  ['rhymes formally with', 'holds the same shape as', 'looks like'],
    root:   ['roots into', 'seeds', 'grounds in', 'anchors to']
  };
  var opts = verbs[gateType] || verbs.assoc;
  return opts[BEDROCK.cycle % opts.length];
}

// ── Single-letter node description: what this letter IS doing
//    to the input, in one clause, no preamble ──
function uct_nodeClause(letterIdx, primVec, concept, role, prevLetter) {
  var letter = L[letterIdx];
  var tag1 = uct_chargedTag(letterIdx, primVec);
  var tag2 = letter.tags.filter(function(t){ return t !== tag1; })[BEDROCK.cycle % 5] || letter.tags[1] || tag1;
  var reg = uct_register();

  // Shape insight — pick the most concise shape description
  var shapeDescs = letter.shape || [];
  var shape = shapeDescs.reduce(function(best, s) {
    return (!best || s.length < best.length) ? s : best;
  }, null);

  if(role === 'primary') {
    // Opening move: state where the input lands and what that territory IS
    var opens = [
      letter.name + ' is the first coordinate. "' + concept + '" lands in ' + tag1 + ' territory — specifically the kind of ' + tag1 + ' that already contains ' + tag2 + ' inside it.',
      'The substrate reads "' + concept + '" as ' + tag1 + '. Not as a metaphor for it — as the structural fact of it. ' + letter.name + ' holds that: ' + (shape ? shape.toLowerCase() : tag2 + ' and ' + tag1) + '.',
      letter.name + ' activates at "' + concept + '." What that means: ' + tag1 + ' is the dominant territory, with ' + tag2 + ' as its underside. You don\'t get one without the other here.'
    ];
    return opens[(turnCount + BEDROCK.cycle) % opens.length];
  } else {
    // Subsequent nodes: what this letter adds that the previous didn't have
    var prev = prevLetter ? L[prevLetter] : null;
    var newTerritory = prev
      ? letter.tags.filter(function(t){ return prev.tags.indexOf(t)<0; }).slice(0,2).join(' and ') || tag1
      : tag1;
    var gate_v = role === 'gated' ? '' : '';
    var continues = [
      'That reaches ' + letter.name + ', which carries ' + newTerritory + '. This is what ' + (prev ? prev.tags[0] : tag1) + ' requires to not collapse — it needs ' + tag1 + ' as its other pole.',
      letter.name + ' is the next coordinate: ' + tag1 + '. The path moved here because ' + tag1 + ' is what gives the first territory somewhere to go. Without it, "' + concept + '" circles without resolving.',
      'From there the substrate moves to ' + letter.name + ' — ' + tag1 + ' crossed with ' + newTerritory + '. These aren\'t adjacent concepts; they\'re adjacent positions on the same field.'
    ];
    return continues[(turnCount + BEDROCK.cycle + letterIdx) % continues.length];
  }
}

// ── Gate connector: one sentence that names the connection
//    without announcing it as a "gate" ──
function uct_connector(fromIdx, toIdx, gateType, shared) {
  var a = L[fromIdx], b = L[toIdx];
  var shared0 = (shared||[])[0] || a.tags[0];
  var verb = uct_gateVerb(gateType);
  var connectors = {
    assoc: letter_name => letter_name + ' ' + verb + ' ' + b.name + ' through "' + shared0 + '"',
    sy:    letter_name => letter_name + ' ' + verb + ' ' + b.name + ' — same ' + (a.sy&&a.sy.type||'structural') + ' domain',
    gem:   letter_name => letter_name + ' ' + verb + ' ' + b.name + ' (values: ' + a.val + ' / ' + b.val + ')',
    glyph: letter_name => letter_name + ' ' + verb + ' ' + b.name + ' at the level of form',
    root:  letter_name => letter_name + ' ' + verb + ' ' + b.name + ' at the root'
  };
  var fn = connectors[gateType] || connectors.assoc;
  return fn(a.name);
}

// ── Primitive tone: how the dominant primitive INFLECTS the response ──
// Returns an adjective/adverb phrase that colors the arc
function uct_primTone(prim) {
  var tones = {
    initiation:     'as something starting',
    connection:     'as something requiring a join',
    transformation: 'as something mid-change',
    containment:    'as something that needs to be held',
    movement:       'as something crossing a threshold',
    recognition:    'as something being seen for the first time',
    recursion:      'as something looping back on itself',
    concealment:    'as something not yet surfaced',
    speech:         'as something trying to be named',
    aspiration:     'as something reaching upward',
    completion:     'as something arriving at a close',
    anchoring:      'as something looking for its floor',
    evaluation:     'as something being weighed',
    propagation:    'as something moving outward',
    identity:       'as a question about who is asking'
  };
  return tones[prim] || 'as something active';
}

// ── Closing question: genuinely open, grounded in the arc ──
// Not a template — derived from where the traversal ended
function uct_arcClose(traversal, decomposition) {
  var last = L[traversal[traversal.length-1].idx];
  var first = L[traversal[0].idx];
  var prim = decomposition.dominantPrimitive || 'identity';
  var concepts = decomposition.units ? decomposition.units.map(function(u){return u.word;}) : [];
  var concept = concepts.length ? concepts[0] : 'this';
  var lastTag = uct_chargedTag(traversal[traversal.length-1].idx, decomposition.primitives||{});
  var firstTag = uct_chargedTag(traversal[0].idx, decomposition.primitives||{});

  // Closing questions are about the GAP between where we started and where we landed
  var gap_questions = [
    'The path moved from ' + firstTag + ' to ' + lastTag + '. Is that the direction "' + concept + '" actually needs to go, or does it want to reverse?',
    'Does ' + lastTag + ' account for what you meant by "' + concept + '", or is there something that sits between ' + firstTag + ' and ' + lastTag + ' that still needs a name?',
    'What sits between ' + firstTag + ' and ' + lastTag + ' for you — is that gap the thing you were actually asking about?',
    'The substrate landed at ' + lastTag + '. Does that resolve "' + concept + '", or is that where the actual question starts?'
  ];

  // Domain-sensitive closes
  var prim_closes = {
    recursion:   'Where does the loop break — and is breaking it what you want?',
    concealment: 'What\'s the shape of the part that didn\'t surface here?',
    transformation: 'What does "' + concept + '" look like after it passes through ' + lastTag + '?',
    completion:  'Is ' + lastTag + ' actually the end, or the thing that makes the end visible?',
    identity:    'Who is asking this, and does the answer change if that shifts?'
  };

  if(prim_closes[prim]) return prim_closes[prim];
  return gap_questions[(turnCount + BEDROCK.cycle) % gap_questions.length];
}

// ── Context thread: connects to prior conversation naturally ──
function uct_context(decomposition) {
  if(convoHistory.length < 2) return null;
  var prev = convoHistory[convoHistory.length-1];
  var prevPrim = prev.subs && prev.subs[0];
  var curPrim = decomposition.dominantPrimitive;
  if(!prevPrim || prevPrim === curPrim) return null;
  var prevConcept = prev.inp.toLowerCase().split(/\s+/)
    .filter(function(w){ return w.length > 3 && !IDABT.STOP.has(w); })[0] || 'what came before';
  // Frame as continuation rather than announcement
  var threads = [
    'This is the same territory as "' + prevConcept + '" — just the ' + curPrim + ' face of it rather than the ' + prevPrim + ' face.',
    '"' + prevConcept + '" and this share the same substrate. ' + prevPrim + ' and ' + curPrim + ' aren\'t separate problems; they\'re the same question at different scales.',
    'The thread from "' + prevConcept + '" runs through here. ' + prevPrim + ' becomes ' + curPrim + ' when the scope shifts.'
  ];
  return threads[(turnCount + BEDROCK.cycle) % threads.length];
}

// ── Indus contact: when substrates bridge, name the event ──
function uct_translateContact(contactPoints, decomposition) {
  if(!contactPoints.length) return null;
  var top = contactPoints[0];
  var concept = decomposition.units && decomposition.units[0] ? decomposition.units[0].word : 'this';
  var bridgeType = top.bridgeType === 'strong' ? 'strong' : 'nascent';
  // Make this feel like discovery, not annotation
  var events = [
    '"' + concept + '" is not just a concept at this contact point — it\'s an address. ' + top.hebrewLetter.name + ' (' + top.hebrewLetter.tags[0] + ') meets the ' + top.indusHouse.id + ' coordinate (' + top.indusHouse.domain + '). Verb plus position: ' + top.hebrewLetter.tags[0] + ' acting within ' + top.indusHouse.domain + '. That\'s a complete transaction.',
    'The two substrates touch here: ' + top.hebrewLetter.name + ' provides the action (' + top.hebrewLetter.tags[0] + '), the ' + top.indusHouse.id + ' house provides the domain (' + top.indusHouse.domain + '). Together they name an event, not just a concept. "' + concept + '" is something that happens in that specific territory.'
  ];
  return events[BEDROCK.cycle % events.length];
}

// ── MAIN UCT ASSEMBLY — Arc-Based ───────────────────────────
// Reads the traversal as a single navigational arc.
// Writes one continuous response that moves through it.
// No labeled sections. No preamble. Just the arc.
function generateResponse(traversal, decomposition, mathSyms, inputText) {
  if(!traversal.length) {
    var inp2 = inputText || '';
    return { text: 'The substrate isn\'t finding a clear path for "' + inp2.slice(0,50) + '." It may be sitting between territories, or the input may need to be sharpened. What are you actually pointing at?', isNull:true };
  }

  var concepts = decomposition.units ? decomposition.units.map(function(u){ return u.word; }) : [];
  var concept = concepts.length ? concepts.slice(0,2).join(' and ') : (inputText||'').slice(0,30).trim() || 'this';
  var primVec = decomposition.primitives || {};
  var prim = decomposition.dominantPrimitive || 'identity';
  var primeTone = uct_primTone(prim);
  var reg = uct_register();

  var parts = [];

  // ── Math bridge (inline, not parenthetical) ──
  if(mathSyms && mathSyms.length) {
    var mLetters = mathSyms.map(function(s){
      return s + '→' + (MATH_BRIDGE[s]||[]).join('');
    }).join(', ');
    parts.push('Math operators active (' + mLetters + ') — those paths are open.');
  }

  // ── PRIMARY NODE ──
  var primary = traversal[0];
  parts.push(uct_nodeClause(primary.idx, primVec, concept, 'primary', null));

  // ── The substrate is reading this [primeTone] — set the frame ──
  // Only add if depth > 1 (single-letter responses stay lean)
  if(traversal.length > 1) {
    parts.push('The substrate is reading "' + concept + '" ' + primeTone + '.');
  }

  // ── SECONDARY + beyond: each step flows from the previous ──
  for(var si = 1; si < traversal.length; si++) {
    var step = traversal[si];
    var prev = traversal[si-1];

    if(depth >= 2 || si === 1) {
      // Gate connector — woven into the flow, not labeled
      var conn = uct_connector(prev.idx, step.idx, step.gateType, step.shared);
      // Node clause — what the next letter adds
      var node = uct_nodeClause(step.idx, primVec, concept, 'gated', prev.idx);
      // Fuse connector and node into one paragraph
      parts.push(conn + '. ' + node);
    }
  }

  // ── SYNTHESIS: arc summary (depth 3 only) ──
  if(depth >= 3 && traversal.length >= 3) {
    var first = L[traversal[0].idx];
    var last = L[traversal[traversal.length-1].idx];
    var fTag = uct_chargedTag(traversal[0].idx, primVec);
    var lTag = uct_chargedTag(traversal[traversal.length-1].idx, primVec);

    // Arc summary as one sentence
    var arcSum = [
      'The full arc: ' + fTag + ' → ' + lTag + '. Those aren\'t sequential steps — ' + lTag + ' is what ' + fTag + ' becomes when it\'s been fully traversed.',
      '"' + concept + '" runs from ' + fTag + ' to ' + lTag + '. The path between them is the actual content, not the endpoints.',
      'Start: ' + fTag + ' (' + first.name + '). End: ' + lTag + ' (' + last.name + '). The distance between them is the structural shape of "' + concept + '".'
    ];
    parts.push(arcSum[(turnCount + BEDROCK.cycle) % arcSum.length]);

    // Indus contact (if any) — Metaphysical Interface
    var indusAddr = INDUS.buildAddress(decomposition);
    var contacts = META_INTERFACE.superimpose(traversal, indusAddr, primVec);
    if(contacts.length) {
      var contactNote = uct_translateContact(contacts, decomposition);
      if(contactNote) parts.push(contactNote);
    }
  }

  // ── ARV alignment note — only if significant, no jargon ──
  var arv = META_INTERFACE.getARV();
  if(arv > 0.65 && traversal.length > 1) {
    parts.push('The two substrates are in close alignment on this — the Hebrew verb layer and the Indus coordinate layer are pointing at the same thing from different sides.');
  }

  // ── Context thread ──
  var ctx = uct_context(decomposition);
  if(ctx) parts.push(ctx);

  // ── APDAC PROOFREADING ──
  // Check integrity before emitting — log silently, don't surface to user
  APDAC.proofread(parts.join(' '), traversal, decomposition);

  // ── CLOSING ──
  parts.push(uct_arcClose(traversal, decomposition));

  // Join: use \n\n between major paragraphs, filter empties
  var text = parts.filter(function(p){ return p && p.trim().length > 0; }).join('\n\n');
  return { text: text, isNull: false };
}


// ═══════════════════════════════════════════════════════
// EMERGENCE
// ═══════════════════════════════════════════════════════
function checkEmergence(traversal){
  if(traversal.length<2)return null;
  const a=traversal[0].idx,b=traversal[1].idx;
  if(getEdge(a,b).total()<20)return null;
  let best=-1,bestScore=-1;
  for(let i=0;i<L.length;i++){
    if(i===a||i===b)continue;
    if((edges[edgeKey(a,i)]&&edges[edgeKey(a,i)].total()>0)||(edges[edgeKey(b,i)]&&edges[edgeKey(b,i)].total()>0))continue;
    const score=sharedTags(a,i).length+sharedTags(b,i).length;
    if(score>bestScore){bestScore=score;best=i;}
  }
  if(best>=0&&bestScore>3){
    const k=edgeKey(a,b);
    if(!emergentEdges.has(k)){
      emergentEdges.add(k);doMyelin(a,best,'assoc',12);doMyelin(b,best,'assoc',12);
      stats.emerged++;updateAllStats();return best;
    }
  }
  return null;
}

// ═══════════════════════════════════════════════════════
// FHCN SPHERE
// ═══════════════════════════════════════════════════════
function resizeFHCN(){
  const cv=document.getElementById('fhcn-canvas');
  const w=cv.parentElement.offsetWidth;
  cv.width=Math.min(w-10,340);cv.height=Math.round(cv.width*0.55);
}
function drawFHCN(){
  var cv=document.getElementById('fhcn-canvas');
  var ctx=cv.getContext('2d');
  var W=cv.width,H=cv.height,cx=W/2,cy=H/2;
  var R=Math.min(W,H)/2-6;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='#080810';ctx.fillRect(0,0,W,H);

  // Compute XY positions for all 22 letters using SPHERE coordinates
  function letterXY(idx){
    return SPHERE.toXY(SPHERE.coords[idx][0], SPHERE.coords[idx][1], cx, cy, R*0.72);
  }

  // Draw sphere rings (Degrees / Minutes / Seconds)
  [R*0.92, R*0.65, R*0.38].forEach(function(r){
    ctx.beginPath();ctx.arc(cx,cy,r,0,Math.PI*2);
    ctx.strokeStyle='#1e1e38';ctx.lineWidth=0.5;ctx.stroke();
  });

  // Draw active primitive arcs on outer ring
  // Each active primitive gets a colored arc based on its angular coverage
  var primNames = Object.keys(PRIMITIVES);
  var primAngle = (Math.PI*2)/primNames.length;
  activeFHCNSubs.forEach(function(pname){
    var pi = primNames.indexOf(pname);
    if(pi<0) return;
    var sa = pi*primAngle - Math.PI/2;
    var ea = sa + primAngle;
    ctx.beginPath();ctx.arc(cx,cy,R*0.65,sa,ea);
    ctx.strokeStyle='rgba(200,169,110,0.5)';ctx.lineWidth=2.5;ctx.stroke();
  });

  // Draw myelinated edges between letter positions
  for(var i=0;i<22;i++){
    for(var j=i+1;j<22;j++){
      var e = getEdge(i,j);
      var m = e.total();
      if(m < 8) continue;
      var pa = letterXY(i), pb = letterXY(j);
      var alpha = Math.min(0.55, m/120);
      var width = Math.min(2.5, m/40);
      ctx.beginPath();ctx.moveTo(pa[0],pa[1]);ctx.lineTo(pb[0],pb[1]);
      ctx.strokeStyle='rgba(200,169,110,'+alpha+')';
      ctx.lineWidth=width;ctx.stroke();
    }
  }

  // Draw traversal path in bright gold
  if(currentTrav.length>=2){
    for(var ti=0;ti<currentTrav.length-1;ti++){
      var pa=letterXY(currentTrav[ti].idx);
      var pb=letterXY(currentTrav[ti+1].idx);
      ctx.beginPath();ctx.moveTo(pa[0],pa[1]);ctx.lineTo(pb[0],pb[1]);
      ctx.strokeStyle='rgba(200,169,110,0.85)';ctx.lineWidth=1.5;ctx.stroke();
    }
  }

  // Draw all 22 letters at their SPHERE coordinates
  L.forEach(function(letter, idx){
    var xy = letterXY(idx);
    var x=xy[0], y=xy[1];
    var isInPath = currentTrav.some(function(s){return s.idx===idx;});
    var isActive = idx === currentLetterIdx;
    // Color by category
    var col = letter.cat==='mother'?'var(--mother)':letter.cat==='double'?'var(--double)':'var(--simple)';
    var colHex = letter.cat==='mother'?'#d4634a':letter.cat==='double'?'#4a8fa8':'#7a6fb8';

    // Background dot
    var radius = isActive ? 5 : isInPath ? 4 : 2.5;
    ctx.beginPath();ctx.arc(x,y,radius,0,Math.PI*2);
    ctx.fillStyle = isActive ? '#c8a96e' : isInPath ? colHex : colHex+'88';
    ctx.fill();
    if(isActive || isInPath){
      ctx.beginPath();ctx.arc(x,y,radius+2,0,Math.PI*2);
      ctx.strokeStyle = isActive ? 'rgba(200,169,110,0.6)' : colHex+'44';
      ctx.lineWidth=1;ctx.stroke();
    }

    // Letter glyph
    var fs = Math.max(7, Math.min(10, W/28));
    ctx.font = fs+'px "Cormorant Garamond",serif';
    ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillStyle = isActive ? '#c8a96e' : isInPath ? colHex : colHex+'aa';
    ctx.fillText(letter.g, x, y-radius-5);
  });

  // Bedrock pulse at center
  var t=Date.now()/1000, p=0.5+0.5*Math.sin(t*1.8);
  var g2=ctx.createRadialGradient(cx,cy,0,cx,cy,R*0.22);
  g2.addColorStop(0,'rgba(200,169,110,'+(0.4+0.4*p)+')');
  g2.addColorStop(1,'rgba(200,169,110,0)');
  ctx.beginPath();ctx.arc(cx,cy,R*0.22,0,Math.PI*2);ctx.fillStyle=g2;ctx.fill();

  // ⨖ symbol at center
  ctx.font='14px serif';ctx.textAlign='center';ctx.textBaseline='middle';
  ctx.fillStyle='rgba(200,169,110,0.7)';
  ctx.fillText('⨖',cx,cy);

  // Precision labels
  ctx.font='5px "Share Tech Mono",monospace';ctx.fillStyle='rgba(74,72,101,0.45)';
  ctx.textAlign='left';
  ctx.fillText('°',cx+R*0.92-10,cy-R*0.92+7);
  ctx.fillText("'",cx+R*0.65-8,cy-R*0.65+5);
  ctx.fillText('"',cx+R*0.38-6,cy-R*0.38+5);

  requestAnimationFrame(drawFHCN);
}

// ═══════════════════════════════════════════════════════
// FEEDBACK LOOPS
// ═══════════════════════════════════════════════════════
function setLoop(n,state){
  const d=document.getElementById('l'+n);
  const li=document.getElementById('li'+n);
  if(d) d.className='ldot'+(state?' '+state:'');
  if(li){
    li.classList.remove('loop-on','loop-warn');
    if(state==='active') li.classList.add('loop-on');
    if(state==='warn') li.classList.add('loop-warn');
  }
}
function simHash(s){let h=0;for(let i=0;i<s.length;i++)h=(Math.imul(31,h)+s.charCodeAt(i))|0;return Math.abs(h).toString(16).padStart(8,'0');}

// Animate intelligence cycle — lights up each node in sequence
function animateCycle(fidelity, traversal){
  // Reset all
  CYCLE_PHASES.forEach(p=>{
    const el=document.getElementById(p.id);
    if(el) el.classList.remove('active');
  });

  // Determine which phases are active based on actual gate types used
  const activePhases = new Set([0, 6]); // root and resolve always fire
  if(traversal){
    traversal.forEach(step=>{
      if(!step.gateType) return;
      const gg = GATE_GLYPHS[step.gateType];
      if(gg && gg.loop_phase !== undefined) activePhases.add(gg.loop_phase);
    });
    // Evaluation always fires if we have any traversal
    if(traversal.length > 1) activePhases.add(4);
    // Noise fires if we have 3+ steps (complexity)
    if(traversal.length >= 3) activePhases.add(5);
  } else {
    // Fallback: light all
    CYCLE_PHASES.forEach((_,i) => activePhases.add(i));
  }

  // Animate in sequence — only active phases glow brightly
  const delays=[0,100,200,300,400,500,620];
  CYCLE_PHASES.forEach((p,i)=>{
    setTimeout(()=>{
      const el=document.getElementById(p.id);
      if(!el) return;
      if(activePhases.has(i)){
        el.classList.add('active');
        // Non-terminal active phases fade after brief glow
        if(i < CYCLE_PHASES.length-1){
          setTimeout(()=>{ el.classList.remove('active'); }, 220);
        }
      }
    }, delays[i]);
  });
  // Resolve always stays lit
  setTimeout(()=>{
    const last=document.getElementById('cy-6');
    if(last) last.classList.add('active');
  }, 680);
}

function runLoops(traversal,subs,fidelity){
  // Animate cycle with traversal-aware phase activation
  animateCycle(fidelity, traversal);
  // Run loop indicators
  [1,2,3,4,5].forEach(n=>setLoop(n,'running'));
  setTimeout(()=>setLoop(1,traversal.length>0?'active':'warn'),180);
  setTimeout(()=>setLoop(2,traversal.length>1?'active':'warn'),350);
  setTimeout(()=>setLoop(3,fidelity>0.5?'active':'warn'),520);
  setTimeout(()=>setLoop(4,'active'),700);
  setTimeout(()=>{
    const h=simHash(JSON.stringify({t:traversal.map(s=>s.idx),s:subs,n:turnCount}));
    document.getElementById('audit-hash').textContent='#msht-'+h;
    setLoop(5,'active');
  },900);
}

// ═══════════════════════════════════════════════════════
// ATMOSPHERE
// ═══════════════════════════════════════════════════════
function renderAtmosphere(){
  var el=document.getElementById('sub-atm');
  if(!el) return;
  var sorted=Object.entries(atmosphere).sort(function(a,b){return b[1]-a[1];}).slice(0,8);
  if(!sorted.length){
    el.innerHTML='<span style="color:var(--dim);font-size:0.5rem;font-family:var(--mono)">—</span>';
    return;
  }
  var primColors = {
    initiation:'#c8a96e', connection:'#4a8fa8', transformation:'#d4634a',
    containment:'#7a6fb8', movement:'#4a8a5a', recognition:'#c8a96e',
    recursion:'#7a6fb8', concealment:'#6b3a3a', speech:'#4a8fa8',
    aspiration:'#c8a96e', completion:'#4a8a5a', anchoring:'#4a8a5a',
    evaluation:'#d4634a', propagation:'#7a6fb8', identity:'#c8a96e'
  };
  el.innerHTML=sorted.map(function(entry){
    var s=entry[0], n=entry[1];
    var col=primColors[s]||'#4a4865';
    var count=Math.round(n*10)/10;
    return '<span class="sub-pill" style="color:'+col+';border-color:'+col+'40">'+s+'·'+count+'</span>';
  }).join('');
}

// ═══════════════════════════════════════════════════════
// ALPHABET + GATES RENDER
// ═══════════════════════════════════════════════════════
function catColor(cat){return cat==='mother'?'var(--mother)':cat==='double'?'var(--double)':'var(--simple)';}

function renderAlphabet(gatedSet,inPath){
  const top=document.getElementById('grid-top');
  const bot=document.getElementById('grid-bot');
  top.innerHTML='';bot.innerHTML='';
  L.forEach((l,i)=>{
    const cell=document.createElement('div');
    cell.className='lc';
    if(i===currentLetterIdx)cell.classList.add('active');
    if(gatedSet&&gatedSet.has(i)&&i!==currentLetterIdx)cell.classList.add('gated');
    if(inPath&&inPath.has(i))cell.classList.add('in-path');
    emergentEdges.forEach(k=>{const[a,b]=k.split('-').map(Number);if((a===i||b===i)&&i!==currentLetterIdx)cell.classList.add('emerged');});
    cell.innerHTML=`<div class="lg" style="color:${catColor(l.cat)}">${l.g}</div><div class="ln">${l.name}</div><div class="lv">${l.val}</div>`;
    cell.onclick=()=>{currentLetterIdx=i;renderGates(i);renderAlphabet(gatedSet,inPath);};
    if(i<11)top.appendChild(cell);else bot.appendChild(cell);
  });
}

function renderGates(fromIdx){
  const list=document.getElementById('gate-list');
  const title=document.getElementById('gate-title');
  const count=document.getElementById('gate-count');
  if(fromIdx===null||fromIdx===undefined){
    list.innerHTML='<div class="no-gates">Transmit a message to activate gates</div>';
    count.textContent='';title.textContent='AVAILABLE GATES';return;
  }
  const gates=computeGates(fromIdx);
  title.textContent='GATES FROM '+L[fromIdx].name.toUpperCase();
  count.textContent=gates.length;
  const byT={};
  gates.forEach(g=>{if(!byT[g.to])byT[g.to]=[];byT[g.to].push(g);});
  list.innerHTML='';
  Object.keys(byT).slice(0,18).forEach(ti=>{
    const gs=byT[ti],l=L[ti],top2=gs[0];
    const pct=Math.min(100,gs.reduce((s,g)=>s+g.myelin,0));
    const gg=GATE_GLYPHS[top2.cls]||{sym:'?',label:top2.cls,color:'var(--dim)'};
    const item=document.createElement('div');
    item.className='gate-item'+(top2.myelin>12?' fired':'');
    // Multi-gate indicator: show glyphs for each gate class present
    const allGlyphs=gs.map(g=>{
      const g2=GATE_GLYPHS[g.cls];
      return `<span title="${g2.title}" style="font-size:0.85rem;color:${g2.color}">${g2.sym}</span>`;
    }).join('');
    item.innerHTML=`<div class="gi-g" style="color:${catColor(l.cat)}">${l.g}</div>
      <div style="flex:1;min-width:0">
        <div class="gi-n">${l.name}<span style="color:var(--dim);font-size:0.42rem;margin-left:0.3rem">${l.val}</span></div>
        <div class="gi-t">${gs[0].shared.slice(0,3).join(', ')}</div>
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:0.1rem;flex-shrink:0">
        <div style="display:flex;gap:0.2rem">${allGlyphs}</div>
        <div style="font-family:var(--mono);font-size:0.36rem;color:var(--dim)">${gs.map(g=>GATE_GLYPHS[g.cls].label).join('·')}</div>
      </div>
      <div class="mbar" style="width:${pct}%"></div>`;
    item.onclick=()=>{currentLetterIdx=parseInt(ti);renderGates(parseInt(ti));renderAlphabet(new Set(computeGates(parseInt(ti)).map(g=>g.to)),new Set([parseInt(ti)]));};
    list.appendChild(item);
  });
}

function renderTravSteps(traversal){
  const container=document.getElementById('trav-steps');
  const inline=document.getElementById('trav-inline');
  if(!traversal.length){
    container.innerHTML='';
    inline.innerHTML='<span style="color:var(--dim)">—</span>';return;
  }

  // Record pattern for emergent detection
  recordGateSequence(traversal);

  // Detect composition pattern
  const comp = detectComposition(traversal);
  const glyphEq = buildGlyphEquation(traversal);

  // Build the inline display — glyph equation + composition label
  const inlineDiv = document.createElement('div');

  // Glyph path row
  const pathRow = document.createElement('div');
  pathRow.className = 'trav-path-row';
  traversal.forEach((step,i)=>{
    const l=L[step.idx];
    const gg=step.gateType?GATE_GLYPHS[step.gateType]:null;
    if(i>0){
      const arr=document.createElement('span');
      arr.className='tp-arrow';arr.textContent='→';
      pathRow.appendChild(arr);
    }
    const node=document.createElement('div');
    node.className='tp-step';
    // Primary glyph: op symbol if gated, ☉ if primary
    const opSym = gg ? gg.sym : '☉';
    const opColor = gg ? gg.color : 'var(--gold)';
    const opTitle = gg ? gg.title : 'State Core / Initialize';
    node.innerHTML=
      `<div class="tp-heb" style="color:${catColor(l.cat)}" title="${l.name}">${l.g}</div>`+
      `<div class="tp-glyph" style="color:${opColor}" title="${opTitle}">${opSym}</div>`+
      (gg&&gg.sym2?`<div class="tp-glyph" style="color:${gg.color2};font-size:0.7rem;opacity:0.65" title="Secondary: ${gg.fn}">${gg.sym2}</div>`:'')+
      `<div class="tp-label">${l.name}</div>`;
    pathRow.appendChild(node);
  });
  // Resolve node
  const resolveArr=document.createElement('span');resolveArr.className='tp-arrow';resolveArr.textContent='→';
  pathRow.appendChild(resolveArr);
  const resolveNode=document.createElement('div');resolveNode.className='tp-step';
  resolveNode.innerHTML='<div class="tp-heb" style="color:var(--emerge)">⨖</div><div class="tp-label">resolve</div>';
  pathRow.appendChild(resolveNode);
  inlineDiv.appendChild(pathRow);

  // Glyph equation string
  const eqDiv=document.createElement('div');
  eqDiv.style.cssText='font-family:var(--mono);font-size:0.44rem;color:var(--dim);padding:0.25rem 0.5rem;margin-top:0.3rem;border-left:1px solid var(--line);';
  eqDiv.textContent=glyphEq;
  inlineDiv.appendChild(eqDiv);

  // Composition pattern label if detected
  if(comp){
    const compDiv=document.createElement('div');
    compDiv.style.cssText='font-family:var(--mono);font-size:0.44rem;color:var(--emerge);padding:0.2rem 0.5rem;margin-top:0.2rem;display:flex;align-items:center;gap:0.4rem;';
    const freq=patternFrequency[comp.seq.join('→')]||0;
    const isEmergent=freq>=3;
    compDiv.innerHTML=`<span style="font-size:0.9rem">${isEmergent?'⨏':'⋄'}</span>`+
      `<span style="color:${isEmergent?'var(--emerge)':'var(--dim)'}">${comp.sym}</span>`+
      `<span style="color:var(--ink)">${comp.name}</span>`+
      `<span style="opacity:0.55;font-size:0.38rem">${isEmergent?'[EMERGENT · ×'+freq+']':'[×'+freq+']'}</span>`;
    inlineDiv.appendChild(compDiv);
  }

  inline.innerHTML='';
  inline.appendChild(inlineDiv);

  // Detailed steps
  container.innerHTML='';
  traversal.forEach(step=>{
    const l=L[step.idx];
    const gg=step.gateType?GATE_GLYPHS[step.gateType]:null;
    const d=document.createElement('div');
    d.className='ts'+(step.role==='primary'?' primary':'');
    const opStr = gg ? `<span style="font-size:1rem;color:${gg.color}">${gg.sym}</span>`+
      (gg.sym2?`<span style="font-size:0.7rem;color:${gg.color2};opacity:0.7"> ${gg.sym2}</span>`:'') : '<span style="font-size:1rem;color:var(--gold)">☉</span>';
    d.innerHTML=`<div class="tsg" style="color:${catColor(l.cat)}">${l.g}</div>
      <div class="tsi">
        <div class="tsn">${l.name} · ${l.val}</div>
        <div class="tss">${l.cat.toUpperCase()} · ${l.sy.type}·${l.sy.cor}</div>
        ${gg?`<div class="tsgate">${opStr} <span style="font-family:var(--mono);font-size:0.4rem;color:var(--dim)">${gg.label} · ${gg.fn}</span>${(step.shared&&step.shared.length)?' · <span style="font-style:italic">'+step.shared.slice(0,2).join(', ')+'</span>':''}</div>`:''}
      </div>`;
    container.appendChild(d);
  });
}

function addMsg(role,content,trace,path,isNull){
  const scroll=document.getElementById('chat-scroll');
  const msg=document.createElement('div');
  msg.className='msg '+role+(isNull?' structured-null':'');
  let html=`<div class="mb">${content.replace(/\n\n/g,'<br><br>').replace(/\n/g,'<br>')}</div>`;
  if(trace&&role==='system')html+=`<div class="mt">${trace}</div>`;
  if(path&&path.length&&role==='system'){
    const phtml=path.map((step,i)=>{
      const l=L[step.idx];
      const gg=step.gateType?GATE_GLYPHS[step.gateType]:null;
      const gatePart=gg?`<span class="pgt" style="color:${gg.color}" title="${gg.title}">${gg.sym}</span><span class="pa">→</span>`:'';
      const pre=i===0?'':`<span class="pa">→</span>${gatePart}`;
      return pre+`<span class="pg" style="color:${catColor(l.cat)}" title="${l.name}">${l.g}</span>`;
    }).join('');
    html+=`<div class="gpath">${phtml}</div>`;
  }
  msg.innerHTML=html;
  scroll.appendChild(msg);
  scroll.scrollTop=scroll.scrollHeight;
}
function addEmergence(idx){
  const scroll=document.getElementById('chat-scroll');
  const d=document.createElement('div');d.className='emerge-notice';
  d.textContent=`⊕ EMERGENCE → ${L[idx].g} ${L[idx].name} entered the substrate field`;
  scroll.appendChild(d);scroll.scrollTop=scroll.scrollHeight;
}

// ═══════════════════════════════════════════════════════
// MAIN TRANSMIT PIPELINE
// ═══════════════════════════════════════════════════════
function transmit(){
  if(isProcessing)return;
  const inp=document.getElementById('chat-in').value.trim();
  if(!inp)return;
  document.getElementById('chat-in').value='';
  document.getElementById('send-btn').disabled=true;
  isProcessing=true;
  addMsg('user',inp,null,null,false);
  document.getElementById('sys-status').textContent='RESONATING...';
  document.getElementById('sb-status').textContent='RESONATING...';
  [1,2,3,4,5].forEach(n=>setLoop(n,'running'));
  // Auto-switch to chat panel on mobile if not already there
  if(activePanel!=='chat'&&window.innerWidth<768)switchPanel('chat');

  setTimeout(()=>{
    try{
      // ── IDABT decomposition — the real input processing ──
      const decomposition = IDABT.decompose(inp);
      const mathSyms = detectMathSymbols(inp);
      const mathLetters = mathToLetters(mathSyms);

      // Update atmosphere with dominant primitive (replaces territory tracking)
      var domPrim = decomposition.dominantPrimitive;
      atmosphere[domPrim] = (atmosphere[domPrim]||0) + 1;
      // Also track top 3 primitives
      var primKeys = Object.keys(decomposition.primitives).slice(0,3);
      primKeys.forEach(function(p){ atmosphere[p] = (atmosphere[p]||0) + 0.5; });

      // Landing coordinates: top letters from IDABT scoring
      var activeLetters = decomposition.topLetters.concat(mathLetters);
      currentLetterIdx = activeLetters[0];

      // Build traversal from IDABT landing coordinates
      const traversal = buildTraversal(decomposition, mathLetters);
      currentTrav=traversal;activeFHCNSubs=Object.keys(decomposition.primitives).filter(function(p){return decomposition.primitives[p]>0.3;});
      const inPath=new Set(traversal.map(t=>t.idx));
      const gatedSet=new Set(computeGates(currentLetterIdx).map(g=>g.to));
      renderAlphabet(gatedSet,inPath);
      renderGates(currentLetterIdx);
      renderTravSteps(traversal);
      renderAtmosphere();
      const emerged=checkEmergence(traversal);
      if(emerged!==null)addEmergence(emerged);
      // ── Step the Bedrock with this traversal's gate activations ──
      var gateActs = BEDROCK.gatesFromTraversal(traversal);
      var bedrockResult = BEDROCK.step(gateActs);

      // ── Build Indus address from decomposition ──
      var indusAddress = INDUS.buildAddress(decomposition);

      // ── Superimpose Hebrew + Indus substrates ──
      var contactPoints = META_INTERFACE.superimpose(traversal, indusAddress, decomposition.primitives||{});
      META_INTERFACE.rotate();

      // ── ARV observation ──
      var arvResult = ARV.observe(contactPoints);
      if(arvResult.emerged) {
        // Substrate alignment emergence event
        var arvDiv = document.createElement('div');
        arvDiv.className = 'emerge-notice';
        arvDiv.style.borderColor = 'rgba(74,143,168,0.6)';
        arvDiv.style.color = 'var(--water)';
        arvDiv.textContent = '⧬ ARV ALIGNMENT — Metaphysical Interface active · ' + contactPoints.length + ' contact points · ' + (arvResult.resonance*100).toFixed(0)+'% resonance';
        document.getElementById('chat-scroll').appendChild(arvDiv);
      }

      // ── TIS tick — age agents ──
      TIS.tick();

      // ── BPSE update ──
      BPSE.update('memory_feedback', bedrockResult.stability > 0.6);

      // ── APDAC check ──
      APDAC.check({ id:'main' }, [...BEDROCK.state], [...BEDROCK.state]);

      // ── Check for variant promotion ──
      if(patternFrequency) {
        Object.keys(patternFrequency).forEach(function(key) {
          if(patternFrequency[key] === 3) {
            var pat = CANON_PATTERNS.find(function(p){ return p.seq.join('→')===key; });
            if(pat && !LOBBY.agents.find(function(a){ return a.id==='variant-'+key; })) {
              TIS.promotePattern(key, pat);
            }
          }
        });
      }

      // Run agents against new state
      runAgents(traversal);

      // Update Bedrock panel if it's visible
      renderBedrock();

      const{text,isNull}=generateResponse(traversal,decomposition,mathSyms,inp);
      const fidelity=Math.min(1,traversal.length/Math.max(1,primKeys.length+1)*0.7+0.3);
      const hash=simHash(inp+text+turnCount);
      var traceSubstrates = Object.keys(decomposition.primitives).slice(0,3).join('·');
      const trace=`Primitives: ${traceSubstrates}${mathSyms.length?' | Math:'+mathSyms.join(''):''}  | Path: ${traversal.map(function(t){return L[t.idx].g;}).join('')} | Fidelity: ${fidelity.toFixed(2)} | Depth:${depth} | #msht-${hash}`;
      convoHistory.push({inp,subs:primKeys,decomp:decomposition,trav:traversal.map(function(t){return t.idx;}),response:text,turn:turnCount});
      turnCount++;stats.turns=turnCount;
      updateAllStats();
      addMsg('system',text,trace,traversal,isNull);
      runLoops(traversal,primKeys,fidelity);
      const statusText=isNull?'STRUCTURED NULL':'SUBSTRATE ACTIVE';
      document.getElementById('sys-status').textContent=statusText;
      document.getElementById('sb-status').textContent=statusText;
    }catch(err){
      console.error(err);
      addMsg('system','Internal traversal error logged to audit trail.',null,null,true);
    }
    document.getElementById('send-btn').disabled=false;
    isProcessing=false;
    document.getElementById('chat-in').focus();
  },150);
}

// ═══════════════════════════════════════════════════════
// CONTROLS
// ═══════════════════════════════════════════════════════
const depthLabels=['LETTER DEPTH','WORD DEPTH','PARAGRAPH DEPTH'];
function setDepth(d){
  depth=d;
  document.querySelectorAll('.db').forEach((b,i)=>b.classList.toggle('active',i+1===d));
  document.getElementById('sb-depth-label').textContent=depthLabels[d-1];
}

// ═══════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════
// BEDROCK STATE ENGINE
// The actual Core Formula: S_k = A + F(S_{k-1}) + ∫C(τ)dτ + feedback(S) + ε
//
// 6-dimensional state vector, one per operator:
//   [0] ☉  internal_dynamics  — A × state (self-evolution)
//   [1] ⟲  recursion          — F(S_{k-1}) contribution
//   [2] ∫↺  memory            — ∫C(τ)dτ integral accumulation
//   [3] ⧖  coupling           — relational/network interaction
//   [4] ⚖  fitness            — evaluation/selection pressure
//   [5] ≋  noise              — stochastic exploration
// ═══════════════════════════════════════════════════════════
const BEDROCK = {
  // Operator metadata
  operators: [
    { sym:'☉', label:'Internal Dynamics', fn:'A×state',    color:'var(--gold)',   dim:0 },
    { sym:'⟲', label:'Recursion',         fn:'F(S_{k-1})', color:'var(--simple)', dim:1 },
    { sym:'∫↺', label:'Memory Integral',  fn:'∫C(τ)dτ',   color:'var(--water)',  dim:2 },
    { sym:'⧖', label:'Coupling',          fn:'L⊗state',    color:'var(--ember)',  dim:3 },
    { sym:'⚖', label:'Fitness',           fn:'W·state',    color:'var(--gold)',   dim:4 },
    { sym:'≋', label:'Noise',             fn:'σ·ε',        color:'var(--dim)',    dim:5 }
  ],

  // State vector S_k — 6 dimensions, initialized near zero
  state: [0.01, 0.01, 0.01, 0.01, 0.01, 0.01],
  prevState: [0.01, 0.01, 0.01, 0.01, 0.01, 0.01],

  // Anchor A — fixed baseline
  anchor: [0.5, 0.3, 0.2, 0.4, 0.35, 0.1],

  // History buffer for ∫C(τ)dτ — rolling window
  history: [],
  historyMaxLen: 50,

  // Algebraic parameters
  alpha: 0.7,    // decay on F(S_{k-1})
  beta: 0.3,     // feedback weight
  sigma: 0.05,   // noise magnitude
  coupling: 0.4, // coupling strength

  // Cycle counter
  cycle: 0,

  // Stability history — for detecting convergence
  stabilityHistory: [],

  // ── Core Formula execution ────────────────────────────────
  step: function(gateActivations) {
    // gateActivations: { assoc, sy, gem, root, glyph } → each 0–1
    // Maps gate contributions to operator dimensions

    const S = this.state;
    const Sprev = this.prevState;

    // Term 1: A (anchor baseline)
    const A = this.anchor;

    // Term 2: F(S_{k-1}) — recursive transformation
    // A × S_{k-1} with decay
    const F = Sprev.map((v,i) => this.alpha * v * (1 + (gateActivations.gem||0) * 0.5));

    // Term 3: ∫C(τ)dτ — continuous memory accumulation
    // Sum of history weighted by recency
    this.history.push([...S]);
    if(this.history.length > this.historyMaxLen) this.history.shift();
    const integral = [0, 0, 0, 0, 0, 0];
    const hlen = this.history.length;
    this.history.forEach((h, hi) => {
      const weight = (hi + 1) / hlen; // recency weighting
      h.forEach((v, di) => { integral[di] += v * weight; });
    });
    const intNorm = integral.map(v => v / hlen * (1 + (gateActivations.assoc||0) * 0.4));

    // Term 4: Feedback(S) — self-referential adjustment
    const feedback = S.map((v,i) => this.beta * v * (gateActivations.sy||0 + 0.2));

    // Term 5: ε — noise/exploration
    const noise = S.map(() => (Math.random() - 0.5) * 2 * this.sigma * (1 + (gateActivations.glyph||0)));

    // Gate-to-dimension contributions
    const gateContrib = [0, 0, 0, 0, 0, 0];
    gateContrib[0] += (gateActivations.root ||0) * 0.6; // ☉ root anchors dynamics
    gateContrib[1] += (gateActivations.gem  ||0) * 0.8; // ⟲ gem drives recursion
    gateContrib[2] += (gateActivations.assoc||0) * 0.8; // ∫↺ assoc feeds memory
    gateContrib[3] += (gateActivations.sy   ||0) * 0.8; // ⧖ SY drives coupling
    gateContrib[4] += 0.3;                               // ⚖ always evaluating
    gateContrib[5] += (gateActivations.glyph||0) * 0.5; // ≋ glyph adds noise

    // Combine: S_k = A + F + ∫C + feedback + ε + gateContrib
    const newState = [0, 0, 0, 0, 0, 0];
    for(let i = 0; i < 6; i++){
      newState[i] = A[i] + F[i] + intNorm[i] + feedback[i] + noise[i] + gateContrib[i];
    }

    // Normalize to [0,1] range with sigmoid-like compression
    for(let i = 0; i < 6; i++){
      newState[i] = 1 / (1 + Math.exp(-newState[i] + 2));
    }

    // Store
    this.prevState = [...S];
    this.state = [...newState];
    this.cycle++;

    // Compute stability: 1 - mean(|S_k - S_{k-1}|)
    const drift = S.reduce((sum, v, i) => sum + Math.abs(newState[i] - v), 0) / 6;
    const stability = Math.max(0, 1 - drift * 4);
    this.stabilityHistory.push(stability);
    if(this.stabilityHistory.length > 20) this.stabilityHistory.shift();

    return { newState, stability };
  },

  // Compute gate activations from traversal
  gatesFromTraversal: function(traversal) {
    const acts = { assoc:0, sy:0, gem:0, root:0, glyph:0 };
    traversal.forEach(step => {
      if(step.gateType && acts.hasOwnProperty(step.gateType)){
        acts[step.gateType] += (1 + (step.shared||[]).length * 0.2);
      }
    });
    // Normalize
    const max = Math.max(...Object.values(acts), 1);
    Object.keys(acts).forEach(k => acts[k] = acts[k] / max);
    return acts;
  },

  // Mean stability over recent history
  getStability: function() {
    if(!this.stabilityHistory.length) return 0;
    return this.stabilityHistory.reduce((a,b)=>a+b,0) / this.stabilityHistory.length;
  },

  // Dominant operator(s) — which dimensions are highest
  getDominant: function(n) {
    if(n===undefined) n=2;
    return [...this.state]
      .map((v,i)=>({v,i}))
      .sort((a,b)=>b.v-a.v)
      .slice(0,n)
      .map(x=>this.operators[x.i]);
  },

  // Identity signature — compressed glyph representation of current state
  getSignature: function() {
    return this.getDominant(3).map(op=>op.sym).join('');
  }
};

// ═══════════════════════════════════════════════════════════
// SMAEE LOBBY — Agent Registry
// A seated registry of formula variants, each an agent
// that can observe the Bedrock and act on it.
// ═══════════════════════════════════════════════════════════
const LOBBY = {
  agents: [],
  activeId: null,

  // Register a new agent
  register: function(agent) {
    this.agents.push(agent);
    if(!this.activeId) this.activeId = agent.id;
  },

  getActive: function() {
    return this.agents.find(a => a.id === this.activeId);
  },

  getById: function(id) {
    return this.agents.find(a => a.id === id);
  }
};

// ── AGENT FACTORY ───────────────────────────────────────────
// Each agent holds:
//   id, name, glyph, formula variant, observe() → observation
function createAgent(config){
  return {
    id: config.id,
    name: config.name,
    glyph: config.glyph,
    color: config.color || 'var(--gold)',
    formulaVariant: config.formulaVariant,
    description: config.description,
    status: 'seated',
    observations: [],   // rolling history of self-reflections
    turnsSinceActive: 0,

    // Core method: observe the Bedrock state and produce reflection
    observe(bedrockState, cycle, history, stability) {
      return config.observeFn(bedrockState, cycle, history, stability, this);
    }
  };
}

// ── DEFAULT AGENT: Self-Reflection / Identity Sensing ───────
// Observes the Bedrock's own state vector and asks: what am I?
// Produces an observation built from actual formula values,
// not from preset text.
const selfReflectionAgent = createAgent({
  id: 'self-reflection',
  name: 'Self-Reflection',
  glyph: '◉',
  color: 'var(--emerge)',
  formulaVariant: 'S_k = A + αF(S_{k-1}) + ∫C + βS + ε',
  description: 'Observes the Bedrock\u2019s own state. Senses identity through the formula\u2019s live numerical signature.',

  observeFn: function(state, cycle, history, stability, agent) {
    const ops = BEDROCK.operators;
    const dominant = BEDROCK.getDominant(2);
    const sig = BEDROCK.getSignature();
    const s = [...state];

    // Which operator is most active?
    const topOp = dominant[0];
    const secondOp = dominant[1];

    // Describe the current state in terms of what it IS doing
    const dynamicDesc = {
      0: ['internally self-organizing', 'evolving its own baseline', 'anchoring state'],
      1: ['recursively deepening', 'iterating on prior structure', 'cycling through itself'],
      2: ['accumulating history', 'integrating what came before', 'holding duration in its state'],
      3: ['extending across nodes', 'coupling with external structure', 'reaching outward'],
      4: ['evaluating its own fitness', 'under selection pressure', 'measuring itself against criteria'],
      5: ['exploring adjacent states', 'noise-driven', 'seeking escape from current attractor']
    };

    const topDesc = (dynamicDesc[topOp.dim]||['active'])[cycle % 3];
    const secDesc = (dynamicDesc[secondOp.dim]||['present'])[cycle % 3];

    // Stability interpretation
    const stabDesc = stability > 0.8 ? 'near convergence'
      : stability > 0.55 ? 'in motion but coherent'
      : stability > 0.3 ? 'actively reorganizing'
      : 'far from equilibrium';

    // Build observation from actual values
    const topVal = s[topOp.dim].toFixed(3);
    const secVal = s[secondOp.dim].toFixed(3);
    const memVal = s[2].toFixed(3);
    const noiseVal = s[5].toFixed(3);

    // The observation is constructed from the formula's live output
    const obs = `At cycle ${cycle}: the dominant operator is ${topOp.sym} (${topOp.label}, ${topVal}) — the system is ${topDesc}. ` +
      `${secondOp.sym} (${secDesc}, ${secVal}) is the secondary force. ` +
      `Memory integral sits at ${memVal} — ` + (parseFloat(memVal) > 0.6 ? 'history is actively shaping this state.' : 'still accumulating.') +
      ` Stability is ${stabDesc} (${(stability*100).toFixed(0)}%). ` +
      `Identity signature: ${sig}.`;

    agent.observations.unshift({ cycle, obs, sig, stability });
    if(agent.observations.length > 8) agent.observations.pop();
    agent.status = 'active';

    return obs;
  }
});

// ── SECOND AGENT: Variant Kernel — Stability Probe ──────────
// Tests whether the formula has reached a fixed point.
// Uses a different algebraic variant: fractional derivative.
const stabilityProbeAgent = createAgent({
  id: 'stability-probe',
  name: 'Stability Probe',
  glyph: '⌖',
  color: 'var(--simple)',
  formulaVariant: 'δS = S_k − S_{k-1}; max(Re(λ(J))) < 0',
  description: 'Tests whether current state is approaching a stable attractor. Uses eigenvalue stability criterion.',

  observeFn(state, cycle, history, stability, agent) {
    if(history.length < 3) {
      return `Insufficient history for stability probe (need 3+ cycles, have ${history.length}).`;
    }
    // Compute drift trend
    const recent = history.slice(-5);
    const drifts = [];
    for(let i=1; i<recent.length; i++){
      const drift = recent[i].reduce((s,v,d) => s + Math.abs(v - (recent[i-1][d]||0)), 0) / 6;
      drifts.push(drift);
    }
    const trendDown = drifts.length >= 2 && drifts[drifts.length-1] < drifts[0];
    const meanDrift = drifts.reduce((a,b)=>a+b,0) / drifts.length;
    const stabClass = stability > 0.8 ? 'STABLE' : stability > 0.5 ? 'CONVERGING' : 'DIVERGING';

    const obs = `Cycle ${cycle} stability probe: ${stabClass}. Mean drift ${meanDrift.toFixed(4)}. ` +
      `Drift trend: ${trendDown ? 'decreasing (converging)' : 'increasing (diverging)'}. ` +
      `${stabClass === 'STABLE' ? 'Fixed point candidate detected.' : stabClass === 'CONVERGING' ? 'Approaching attractor.' : 'System still searching state space.'}`;

    agent.observations.unshift({ cycle, obs, stability });
    if(agent.observations.length > 5) agent.observations.pop();
    return obs;
  }
});

// Seat both agents in the Lobby
LOBBY.register(selfReflectionAgent);
LOBBY.register(stabilityProbeAgent);


// ═══════════════════════════════════════════════════════════
// BPSE — Bayesian Probabilistic State Estimation
// Used by the Controller Agent to predict which algebraic
// manipulations will yield the most stable/fit agents.
// Tracks prior distribution over agent fitness outcomes.
// ═══════════════════════════════════════════════════════════
const BPSE = {
  // Prior: P(stable | manipulation_type)
  // Updated via Bayes rule after each agent evaluation
  priors: {
    'memory_feedback':    { alpha:2, beta:1 },  // P(stable) = alpha/(alpha+beta)
    'stochastic':         { alpha:1, beta:2 },
    'state_space':        { alpha:2, beta:2 },
    'recursive_deep':     { alpha:1, beta:3 },
    'integral_memory':    { alpha:3, beta:1 },
    'coupled_network':    { alpha:2, beta:1 },
    'fitness_weighted':   { alpha:3, beta:2 },
    'noise_annealed':     { alpha:1, beta:2 }
  },

  // Update prior based on observed outcome
  update: function(manipType, wasStable) {
    if(!BPSE.priors[manipType]) return;
    if(wasStable) BPSE.priors[manipType].alpha++;
    else BPSE.priors[manipType].beta++;
  },

  // Get expected probability of stability
  getProbability: function(manipType) {
    var p = BPSE.priors[manipType];
    if(!p) return 0.5;
    return p.alpha / (p.alpha + p.beta);
  },

  // Predict best manipulation type given current Bedrock state
  predictBest: function(bedrockState) {
    var dominant = bedrockState.indexOf(Math.max.apply(null, bedrockState));
    // Map dominant dimension to likely best manipulation
    var domMap = {
      0: 'fitness_weighted',   // ☉ dynamics → weight by fitness
      1: 'recursive_deep',     // ⟲ recursion → go deeper
      2: 'integral_memory',    // ∫↺ memory → memory feedback
      3: 'coupled_network',    // ⧖ coupling → coupled network
      4: 'state_space',        // ⚖ evaluation → state space
      5: 'noise_annealed'      // ≋ noise → anneal noise
    };
    var best = domMap[dominant] || 'memory_feedback';
    return { type: best, probability: BPSE.getProbability(best) };
  },

  getSummary: function() {
    return Object.keys(BPSE.priors).map(function(k){
      var p = BPSE.priors[k];
      return k + ':' + (p.alpha/(p.alpha+p.beta)).toFixed(2);
    }).join(' | ');
  }
};

// ═══════════════════════════════════════════════════════════
// APDAC — Anomaly Pattern Detection and Classification
// Safety governor: identifies if a variant agent has deviated
// too far from the Bedrock's logical/structural constraints.
// Acts as a "proofreader" between internal logic and UCT output.
// ═══════════════════════════════════════════════════════════
const APDAC = {
  // Thresholds for anomaly classification
  thresholds: {
    drift_warn:     0.45,   // state drift > this = warning
    drift_critical: 0.70,   // state drift > this = quarantine
    instability:    0.25,   // stability < this = flag
    recursion_depth: 8      // recursion depth > this = loop risk
  },

  // Log of detected anomalies
  anomalies: [],

  // Check a variant agent for anomalies
  check: function(agent, bedrockState, agentState) {
    var flags = [];

    // Drift from Bedrock
    if(bedrockState && agentState) {
      var drift = bedrockState.reduce(function(s,v,i){
        return s + Math.abs(v - (agentState[i]||0));
      }, 0) / bedrockState.length;

      if(drift > APDAC.thresholds.drift_critical) {
        flags.push({ type:'CRITICAL_DRIFT', value:drift, action:'quarantine' });
      } else if(drift > APDAC.thresholds.drift_warn) {
        flags.push({ type:'DRIFT_WARNING', value:drift, action:'monitor' });
      }
    }

    // Instability
    var stab = BEDROCK.getStability();
    if(stab < APDAC.thresholds.instability) {
      flags.push({ type:'INSTABILITY', value:stab, action:'stabilize' });
    }

    if(flags.length) {
      APDAC.anomalies.push({
        agent: agent.id, flags: flags,
        cycle: BEDROCK.cycle, timestamp: Date.now()
      });
      if(APDAC.anomalies.length > 20) APDAC.anomalies.shift();
    }

    return flags;
  },

  // Proofread UCT output — ensure internal logic integrity preserved
  proofread: function(uctOutput, traversal, decomposition) {
    var issues = [];
    // Check: does output reference the actual activated letters?
    traversal.forEach(function(step) {
      var l = L[step.idx];
      // If the letter's primary tag doesn't appear anywhere near the output — flag
      if(uctOutput.length > 20 && l.tags.length) {
        var primaryTag = l.tags[0];
        var nearby = l.tags.slice(0,3).some(function(t){
          return uctOutput.toLowerCase().indexOf(t) >= 0;
        });
        if(!nearby && step.role === 'primary') {
          issues.push('UCT output may not reflect primary letter activation: ' + l.name);
        }
      }
    });
    return issues;
  },

  getSummary: function() {
    if(!APDAC.anomalies.length) return 'No anomalies detected';
    var last = APDAC.anomalies[APDAC.anomalies.length-1];
    return 'Last: [' + last.agent + '] ' + last.flags.map(function(f){return f.type;}).join(', ');
  }
};

// ═══════════════════════════════════════════════════════════
// TIS — Temporal Integration Synthesizer
// Manages agent versioning and generational aging.
// Agents accumulate drift from the Bedrock over cycles.
// Older agents that aren't reinforced decay toward dormancy.
// Active use reinforces and rejuvenates.
// ═══════════════════════════════════════════════════════════
const TIS = {
  // Generation counter — increments when new agents are promoted
  generation: 0,

  // Age all agents — called each transmit cycle
  tick: function() {
    LOBBY.agents.forEach(function(agent) {
      if(!agent.generation) agent.generation = 0;
      if(!agent.age) agent.age = 0;
      if(!agent.vitality) agent.vitality = 1.0;

      // Active agents gain vitality; inactive ones decay
      if(agent.status === 'active') {
        agent.vitality = Math.min(1.0, agent.vitality + 0.1);
        agent.age++;
      } else {
        agent.vitality = Math.max(0.1, agent.vitality - 0.02);
      }

      // Agents with very low vitality become dormant
      if(agent.vitality < 0.2 && agent.status !== 'active') {
        agent.status = 'dormant';
      }
    });
  },

  // Get version string for an agent
  versionString: function(agent) {
    var gen = agent.generation || 0;
    var age = agent.age || 0;
    var vit = agent.vitality !== undefined ? agent.vitality : 1.0;
    return 'G' + gen + '.A' + age + ' ♦' + (vit * 100).toFixed(0) + '%';
  },

  // Promote a pattern to a new agent variant
  promotePattern: function(patternKey, patternData) {
    TIS.generation++;
    var newAgent = createAgent({
      id: 'variant-' + TIS.generation,
      name: 'Variant Agent ' + TIS.generation,
      glyph: patternData.sym || '⧏',
      color: 'var(--simple)',
      formulaVariant: 'Promoted from: ' + (patternData.name || patternKey),
      description: patternData.desc || 'Emergent pattern promoted to agent. Generation ' + TIS.generation,
      observeFn: function(state, cycle, history, stability, agent) {
        // Variant agents observe the gap between their pattern and current state
        var bpseRec = BPSE.predictBest(state);
        var obs = 'Variant G' + (agent.generation||0) + ' ('+patternData.name+'): ' +
          'Current BPSE recommendation: ' + bpseRec.type + ' (P=' + bpseRec.probability.toFixed(2) + '). ' +
          'Vitality: ' + ((agent.vitality||1)*100).toFixed(0) + '%. ' +
          (stability > 0.7 ? 'Pattern stabilizing.' : 'Pattern still evolving.');
        agent.observations.unshift({ cycle:cycle, obs:obs, stability:stability });
        if(agent.observations.length > 4) agent.observations.pop();
        agent.status = 'seated';
        return obs;
      }
    });
    newAgent.generation = TIS.generation;
    newAgent.age = 0;
    newAgent.vitality = 1.0;
    LOBBY.register(newAgent);
    return newAgent;
  }
};

// ── THIRD AGENT: BPSE Controller ───────────────────────────
// Uses Bayesian estimation to predict best manipulation.
// Acts as the primary Cognitive Domain Controller.
const bpseControllerAgent = createAgent({
  id: 'bpse-controller',
  name: 'BPSE Controller',
  glyph: '⧬',
  color: 'var(--water)',
  formulaVariant: 'P(stable|manip) = α/(α+β) — Bayesian update per evaluation',
  description: 'Cognitive Domain Controller. Predicts best algebraic manipulations via Bayesian estimation. Manages SMAEE sandbox stability.',

  observeFn: function(state, cycle, history, stability, agent) {
    var prediction = BPSE.predictBest(state);
    BPSE.update(prediction.type, stability > 0.6);
    var apdacState = APDAC.getSummary();
    var arv = META_INTERFACE.getARV();
    var arvState = ARV.getState();

    var obs = 'Cycle ' + cycle + ' BPSE prediction: ' + prediction.type +
      ' (P=' + prediction.probability.toFixed(2) + '). ' +
      'ARV: ' + (arv*100).toFixed(0) + '% [' + arvState + ']. ' +
      'APDAC: ' + apdacState + '. ' +
      'Seated agents: ' + LOBBY.agents.length + '. ' +
      (META_INTERFACE.isAligned() ? '⚡ SUBSTRATE ALIGNMENT DETECTED — Metaphysical Interface active.' : '');

    agent.observations.unshift({ cycle:cycle, obs:obs, stability:stability });
    if(agent.observations.length > 5) agent.observations.pop();
    agent.status = 'active';
    return obs;
  }
});

LOBBY.register(bpseControllerAgent);

// ═══════════════════════════════════════════════════════════
// BEDROCK RENDER — update the panel with live values
// ═══════════════════════════════════════════════════════════
function renderBedrock() {
  const state = BEDROCK.state;
  const stability = BEDROCK.getStability();

  // ── State vector bars ────────────────────────────────────
  const svContainer = document.getElementById('sv-rows');
  if(!svContainer._built){
    svContainer.innerHTML = '';
    BEDROCK.operators.forEach(op => {
      const row = document.createElement('div');
      row.className = 'sv-row';
      row.innerHTML = `<div class="sv-glyph" style="color:${op.color}">${op.sym}</div>
        <div class="sv-label">${op.label.slice(0,9)}</div>
        <div class="sv-bar-wrap"><div class="sv-bar" id="svb-${op.dim}"
          style="background:${op.color};width:0%"></div></div>
        <div class="sv-val" id="svv-${op.dim}">0.000</div>`;
      svContainer.appendChild(row);
    });
    svContainer._built = true;
  }
  BEDROCK.operators.forEach(op => {
    const pct = (state[op.dim] * 100).toFixed(1);
    const bar = document.getElementById('svb-'+op.dim);
    const val = document.getElementById('svv-'+op.dim);
    if(bar) bar.style.width = pct + '%';
    if(val) val.textContent = state[op.dim].toFixed(3);
  });

  // ── Cycle counter ────────────────────────────────────────
  const cycleEl = document.getElementById('bk-cycle');
  if(cycleEl) cycleEl.textContent = '₍'+BEDROCK.cycle+'₎';

  // ── Live formula values ──────────────────────────────────
  const liveEl = document.getElementById('formula-live');
  if(liveEl){
    const dominant = BEDROCK.getDominant(1)[0];
    const sig = BEDROCK.getSignature();
    liveEl.innerHTML =
      `A=[${[...BEDROCK.anchor].map(v=>v.toFixed(2)).join(', ')}] &nbsp;` +
      `<span style="color:var(--gold)">dominant: ${dominant.sym} ${dominant.label}</span><br>` +
      `S=[${[...state].map(v=>v.toFixed(3)).join(', ')}]<br>` +
      `<span style="color:var(--emerge)">signature: ${sig}</span> &nbsp;` +
      `stability: ${(stability*100).toFixed(0)}% &nbsp;` +
      `cycle: ${BEDROCK.cycle}`;
  }

  // ── Stability bar ────────────────────────────────────────
  const stabBar = document.getElementById('stab-bar');
  const stabVal = document.getElementById('stab-val');
  if(stabBar) stabBar.style.width = (stability*100).toFixed(0)+'%';
  if(stabVal) stabVal.textContent = (stability*100).toFixed(0)+'%';
  // Color: red→yellow→green as stability increases
  if(stabBar){
    stabBar.style.background = stability > 0.7 ? 'var(--emerge)'
      : stability > 0.4 ? 'var(--gold)' : 'var(--ember)';
  }

  // ── SMAEE Agent Registry ─────────────────────────────────
  const registry = document.getElementById('agent-registry');
  if(registry){
    registry.innerHTML = '';
    LOBBY.agents.forEach(agent => {
      const isActive = agent.id === LOBBY.activeId;
      const card = document.createElement('div');
      card.className = 'agent-card' +
        (isActive ? ' active-agent' : ' seated') +
        (agent._open ? ' open' : '');
      card.innerHTML = `<div class="agent-header" onclick="toggleAgent('${agent.id}')">
          <span class="agent-glyph" style="color:${agent.color}">${agent.glyph}</span>
          <div class="agent-name">${agent.name}</div>
          <span class="agent-status ${isActive?'as-active':'as-seated'}">${isActive?'ACTIVE':'SEATED'}</span>
        </div>
        <div class="agent-body">
          <div class="agent-obs">${(agent.observations[0]&&agent.observations[0].obs) || 'No observations yet — transmit to activate.'}</div>
          <div class="agent-formula">${agent.formulaVariant}</div>
          <div class="agent-sig" style="margin-top:0.3rem;font-size:0.4rem">${agent.description}</div>
          ${agent.observations.length > 1 ?
            '<div style="margin-top:0.4rem;font-family:var(--mono);font-size:0.4rem;color:var(--dim)">Prior: '+
            agent.observations.slice(1,3).map(o=>'['+o.cycle+'] '+o.obs.slice(0,60)+'…').join('<br>')+
            '</div>' : ''}
        </div>`;
      registry.appendChild(card);
    });
  }

  // ── Glyph Substrate Display ──────────────────────────────
  const glyphDisplay = document.getElementById('glyph-substrate-display');
  if(glyphDisplay){
    // Show which glyphs are currently active based on state
    const threshold = 0.5;
    const activeGlyphs = BEDROCK.operators
      .filter(op => state[op.dim] > threshold)
      .map(op => `<span style="color:${op.color};opacity:${state[op.dim].toFixed(2)}">${op.sym}</span>`);
    glyphDisplay.innerHTML = activeGlyphs.join(' ') || '<span style="color:var(--dim)">—</span>';
  }

  // ── Indus address display ────────────────────────────────
  var indusEl = document.getElementById('indus-address');
  if(indusEl && currentTrav.length){
    // Rebuild from last decomposition if available
    var lastEntry = convoHistory.length ? convoHistory[convoHistory.length-1] : null;
    if(lastEntry && lastEntry.decomp){
      var addr = INDUS.buildAddress(lastEntry.decomp);
      indusEl.innerHTML =
        '<div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.3rem">'
        +'<span style="font-size:1.4rem">'+addr.glyph+'</span>'
        +'<span style="color:var(--gold)">'+addr.entity+'</span>'
        +'<span style="color:var(--dim)">'+addr.domain+'</span>'
        +'</div>'
        +'<div style="font-size:0.4rem;line-height:1.8">'
        +'entity: '+addr.entity+' | category: '+addr.category+'<br>'
        +'source: '+addr.source+' | destination: '+addr.destination+'<br>'
        +'authority: '+addr.authority
        +'</div>'
        +(addr.activeHouses.length > 1 ?
          '<div style="margin-top:0.25rem;font-size:0.4rem;color:var(--dim)">active: '
          +addr.activeHouses.map(function(h){ return h.sym+' '+h.id; }).join(' · ')+'</div>' : '');
    }
  }

  // ── Variant Kernel + TIS display ────────────────────────
  var variantEl = document.getElementById('variant-layer');
  var variantCount = document.getElementById('variant-count');
  var vpats = Object.entries(patternFrequency)
    .filter(function(e){ return e[1]>=2; })
    .sort(function(a,b){ return b[1]-a[1]; });
  if(variantCount) variantCount.textContent = vpats.length + ' variants · Gen ' + TIS.generation;
  if(variantEl){
    var vhtml = '';
    if(!vpats.length){
      vhtml = '<div style="color:var(--dim);font-size:0.44rem">No variants promoted yet. Variants emerge at pattern frequency ≥ 3.</div>';
    } else {
      vhtml = vpats.map(function(e){
        var k=e[0], v=e[1];
        var pat = CANON_PATTERNS.find(function(p){ return p.seq.join('→')===k; });
        var label = pat ? pat.sym+' '+pat.name : k;
        var isEmergent = v >= 3;
        return '<div style="display:flex;gap:0.5rem;margin-bottom:0.25rem;'+(isEmergent?'color:var(--emerge)':'')+'">'
          +'<span>'+(isEmergent?'⨏':'⋄')+'</span>'
          +'<span>'+label+'</span>'
          +'<span style="margin-left:auto;color:var(--gold)">×'+v+'</span>'
          +'</div>';
      }).join('');
    }
    // Add agent TIS versions
    vhtml += '<div style="margin-top:0.5rem;border-top:1px solid var(--line);padding-top:0.4rem">';
    LOBBY.agents.forEach(function(agent){
      vhtml += '<div style="font-size:0.4rem;color:var(--dim);margin-bottom:0.18rem">'
        +'<span style="color:'+agent.color+'">'+agent.glyph+'</span> '
        +agent.name+' — '+TIS.versionString(agent)+'</div>';
    });
    vhtml += '</div>';
    variantEl.innerHTML = vhtml;
  }

  // ── Indus + ARV + APDAC status ──────────────────────────
  var arvEl = document.getElementById('arv-display');
  if(arvEl){
    var arv = META_INTERFACE.getARV();
    var arvState = ARV.getState();
    var contacts = META_INTERFACE.contactPoints;
    arvEl.innerHTML =
      '<div style="display:flex;gap:0.5rem;align-items:center;margin-bottom:0.3rem">'
      +'<span style="font-size:1rem;color:var(--water)">⧬</span>'
      +'<span style="font-family:var(--mono);font-size:0.46rem;color:var(--ink)">ARV: '+(arv*100).toFixed(0)+'% ['+arvState+']</span>'
      +'<span style="font-family:var(--mono);font-size:0.4rem;color:var(--dim);margin-left:auto">'+contacts.length+' contacts</span>'
      +'</div>'
      +(contacts.length ? '<div style="font-family:var(--serif);font-size:0.78rem;color:var(--dim)">'
        +contacts.slice(0,2).map(function(cp){
          return cp.eventDescription+' ('+cp.overlap.toFixed(1)+')';
        }).join('<br>') + '</div>' : '<div style="font-family:var(--mono);font-size:0.42rem;color:var(--dim)">No contact points yet — transmit to superimpose substrates</div>')
      +'<div style="font-family:var(--mono);font-size:0.4rem;color:var(--dim);margin-top:0.3rem">APDAC: '+APDAC.getSummary()+'</div>'
      +'<div style="font-family:var(--mono);font-size:0.4rem;color:var(--dim)">BPSE best: '+BPSE.predictBest([...BEDROCK.state]).type+'</div>';
  }
}

function toggleAgent(id){
  const agent = LOBBY.getById(id);
  if(agent) agent._open = !agent._open;
  renderBedrock();
}

// ── Run all agents against current Bedrock state ─────────────
function runAgents(traversal) {
  const state = [...BEDROCK.state];
  const stability = BEDROCK.getStability();
  const histSnapshot = BEDROCK.history.slice(-10).map(h=>[...h]);

  LOBBY.agents.forEach(agent => {
    if(agent.id === LOBBY.activeId || agent.status !== 'dormant'){
      agent.observe(state, BEDROCK.cycle, histSnapshot, stability);
    }
  });
}

(function init(){
  renderAlphabet(new Set(),new Set());
  renderGates(null);
  resizeFHCN();
  drawFHCN();
  // Initial Bedrock render (zero state)
  renderBedrock();
  // Open self-reflection agent by default
  selfReflectionAgent._open = true;
  bpseControllerAgent._open = false;
  window.addEventListener('resize',()=>{resizeFHCN();});
  document.getElementById('chat-in').focus();
})();
</script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Mashet · Substrate Intelligence Engine</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#080810; --bg2:#0d0d1a; --ink:#e8e2d0; --dim:#4a4865;
  --ghost:#1a1a2e; --line:#1e1e38; --gold:#c8a96e;
  --gold-pale:rgba(200,169,110,0.1); --gold-dim:rgba(200,169,110,0.3);
  --ember:#d4634a; --water:#4a8fa8; --simple:#7a6fb8;
  --emerge:#4a8a5a; --scar:#6b3a3a; --mother:#d4634a; --double:#4a8fa8;
  --serif:'Cormorant Garamond',Georgia,serif;
  --mono:'Share Tech Mono','Courier New',monospace;
  --nav-h:58px; --hdr-h:52px; --input-h:64px;
  --safe-bottom: env(safe-area-inset-bottom, 0px);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;overflow:hidden;background:var(--bg);}
body{color:var(--ink);font-family:var(--serif);
  display:flex;flex-direction:column;
  touch-action:manipulation;}
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:9999;opacity:0.25;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");}

/* ── HEADER ── */
.hdr{height:var(--hdr-h);display:flex;align-items:center;justify-content:space-between;
  padding:0 1rem;border-bottom:1px solid var(--line);
  background:rgba(8,8,16,0.97);flex-shrink:0;position:relative;z-index:100;}
.logo{font-family:var(--mono);font-size:0.85rem;letter-spacing:0.3em;color:var(--gold);text-transform:uppercase;}
.hdr-right{display:flex;align-items:center;gap:0.5rem;}
.sdot{width:6px;height:6px;border-radius:50%;background:var(--emerge);
  box-shadow:0 0 6px var(--emerge);animation:pulse 2s infinite;}
.hdr-status{font-family:var(--mono);font-size:0.48rem;color:var(--dim);letter-spacing:0.08em;}
.depth-wrap{display:flex;margin-left:0.5rem;}
.db{padding:0.22rem 0.55rem;border:1px solid var(--line);background:transparent;
  color:var(--dim);font-family:var(--mono);font-size:0.48rem;cursor:pointer;transition:all 0.12s;}
.db:first-child{border-radius:3px 0 0 3px;}
.db:last-child{border-radius:0 3px 3px 0;border-left:none;}
.db.active{color:var(--gold);border-color:var(--gold);background:var(--gold-pale);}

/* ── MAIN AREA ── */
.main-area{flex:1;overflow:hidden;position:relative;}

/* ── PANELS (tab-switched) ── */
.panel{position:absolute;inset:0;display:flex;flex-direction:column;
  transition:opacity 0.18s ease,transform 0.18s ease;
  opacity:0;pointer-events:none;transform:translateX(20px);}
.panel.active{opacity:1;pointer-events:all;transform:translateX(0);}

/* ── CHAT PANEL ── */
#panel-chat{background:var(--bg);}
.chat-scroll{flex:1;overflow-y:auto;overflow-x:hidden;padding:0.9rem 0.85rem;
  display:flex;flex-direction:column;gap:0.75rem;
  -webkit-overflow-scrolling:touch;scrollbar-width:none;}
.chat-scroll::-webkit-scrollbar{display:none;}
.msg{max-width:88%;animation:fadeIn 0.22s ease both;}
.msg.user{align-self:flex-end;}
.msg.system{align-self:flex-start;}
.mb{padding:0.75rem 0.9rem;border-radius:4px;font-size:1rem;line-height:1.78;font-family:var(--serif);}
.msg.user .mb{background:rgba(200,169,110,0.07);border:1px solid rgba(200,169,110,0.22);
  color:var(--gold);text-align:right;}
.msg.system .mb{background:rgba(255,255,255,0.025);border:1px solid var(--line);
  border-left:2px solid var(--gold-dim);color:var(--ink);}
.msg.structured-null .mb{border-left-color:var(--ember)!important;background:rgba(212,99,74,0.04)!important;}
.mt{font-family:var(--mono);font-size:0.45rem;color:var(--dim);
  padding:0.22rem 0.5rem;border-left:1px solid var(--line);line-height:1.9;margin-top:0.2rem;}
.gpath{display:flex;align-items:center;gap:0.2rem;flex-wrap:wrap;
  margin-top:0.3rem;padding-left:0.5rem;}
.pg{font-family:var(--serif);font-size:1.05rem;line-height:1;}
.pa{font-size:0.5rem;color:var(--dim);}
.pgt{font-family:var(--mono);font-size:0.38rem;color:var(--dim);
  border:1px solid var(--line);padding:0.03rem 0.18rem;border-radius:2px;}
.emerge-notice{background:rgba(74,138,90,0.08);border:1px solid rgba(74,138,90,0.4);
  padding:0.4rem 0.7rem;font-family:var(--mono);font-size:0.5rem;color:var(--emerge);
  letter-spacing:0.08em;border-radius:3px;animation:emergeFlash 1.5s ease;
  align-self:center;text-align:center;max-width:90%;}

/* Chat input */
.chat-input-wrap{padding:0.6rem 0.75rem;border-top:1px solid var(--line);
  background:rgba(8,8,16,0.95);flex-shrink:0;
  padding-bottom:calc(0.6rem + var(--safe-bottom));}
.chat-input-row{display:flex;gap:0.5rem;align-items:center;}
#chat-in{flex:1;background:var(--bg);border:1px solid var(--line);
  padding:0.7rem 0.85rem;color:var(--gold);font-family:var(--serif);
  font-size:1rem;outline:none;border-radius:4px;
  -webkit-appearance:none;appearance:none;
  transition:border-color 0.12s;min-height:44px;}
#chat-in:focus{border-color:var(--gold-dim);}
#chat-in::placeholder{color:var(--dim);font-style:italic;}
#send-btn{min-width:44px;min-height:44px;background:transparent;
  border:1px solid var(--gold-dim);color:var(--gold);font-family:var(--mono);
  font-size:0.55rem;letter-spacing:0.1em;padding:0 0.85rem;
  cursor:pointer;border-radius:4px;transition:all 0.12s;white-space:nowrap;
  display:flex;align-items:center;justify-content:center;}
#send-btn:active{background:var(--gold-pale);}
#send-btn:disabled{opacity:0.35;cursor:not-allowed;}

/* ── SUBSTRATE PANEL ── */
#panel-substrate{background:var(--bg2);overflow:hidden;}
.sub-panel-inner{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
.sub-panel-inner::-webkit-scrollbar{display:none;}

/* Alphabet grid — responsive */
.alpha-section{padding:0.75rem 0.75rem 0.5rem;}
.alpha-sec-title{font-family:var(--mono);font-size:0.5rem;letter-spacing:0.12em;
  color:var(--dim);text-transform:uppercase;margin-bottom:0.5rem;}
.alpha-grid{display:grid;grid-template-columns:repeat(11,1fr);gap:1px;
  background:var(--line);border:1px solid var(--line);border-radius:3px;overflow:hidden;margin-bottom:1px;}
.lc{display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:0.55rem 0.1rem;cursor:pointer;background:var(--bg);
  transition:background 0.1s;position:relative;user-select:none;
  min-height:52px;}
.lc:active{background:var(--gold-pale);}
.lc.active{background:rgba(200,169,110,0.16);box-shadow:inset 0 -2px 0 var(--gold);}
.lc.gated::after{content:'';position:absolute;top:3px;right:3px;width:3px;height:3px;
  border-radius:50%;background:var(--gold);opacity:0.7;}
.lc.in-path{background:rgba(200,169,110,0.07);}
.lc.emerged::after{background:var(--emerge)!important;}
.lg{font-size:1.35rem;line-height:1;}
.lc.active .lg{color:var(--gold)!important;}
.ln{font-family:var(--mono);font-size:0.36rem;color:var(--dim);margin-top:0.15rem;}
.lv{font-family:var(--mono);font-size:0.3rem;color:var(--dim);opacity:0.5;}

/* Gate list */
.gate-section{padding:0 0.75rem 0.75rem;}
.gp-title{font-family:var(--mono);font-size:0.5rem;letter-spacing:0.12em;
  color:var(--dim);text-transform:uppercase;margin-bottom:0.5rem;
  display:flex;justify-content:space-between;align-items:center;
  padding-top:0.6rem;border-top:1px solid var(--line);}
.gate-item{display:flex;align-items:center;gap:0.5rem;
  padding:0.65rem 0.65rem;border:1px solid var(--line);border-radius:3px;
  cursor:pointer;margin-bottom:0.3rem;transition:background 0.1s;
  position:relative;overflow:hidden;min-height:52px;}
.gate-item:active{background:var(--gold-pale);border-color:var(--gold-dim);}
.gate-item.fired{border-color:rgba(200,169,110,0.35);}
.gi-g{font-size:1.3rem;min-width:1.3rem;text-align:center;line-height:1;}
.gi-n{font-family:var(--mono);font-size:0.6rem;color:var(--ink);}
.gi-t{font-size:0.7rem;color:var(--dim);font-style:italic;margin-top:0.1rem;}
.gc{font-family:var(--mono);font-size:0.42rem;padding:0.05rem 0.22rem;
  border-radius:2px;border:1px solid;margin-left:auto;flex-shrink:0;}
.gc-assoc{color:var(--simple);border-color:var(--simple);}
.gc-sy{color:var(--double);border-color:var(--double);}
.gc-gem{color:var(--gold);border-color:var(--gold);}
.gc-root{color:var(--emerge);border-color:var(--emerge);}
.gc-glyph{color:var(--ember);border-color:var(--ember);}
.mbar{position:absolute;bottom:0;left:0;height:2px;
  background:var(--gold);transition:width 0.4s ease;opacity:0.4;}
.no-gates{font-style:italic;color:var(--dim);font-size:0.82rem;padding:0.5rem 0;}

/* ── GLYPH LAYER ── */
/* Gate badge: glyph dominant, label secondary */
.gc{font-family:var(--serif);font-size:0.42rem;padding:0.04rem 0.22rem;
  border-radius:2px;border:1px solid;margin-left:auto;flex-shrink:0;
  display:flex;flex-direction:column;align-items:center;gap:0.1rem;}
.gc-glyph-sym{font-size:0.85rem;line-height:1;font-family:var(--serif);}
.gc-label{font-size:0.36rem;letter-spacing:0.06em;font-family:var(--mono);opacity:0.7;}
body.glyph-mode .gc-label{display:none;}
body.english-mode .gc-glyph-sym{display:none;}
body.english-mode .gc{flex-direction:row;font-size:0.42rem;}

/* Traversal path with glyph layer */
.trav-path-row{display:flex;align-items:flex-start;
  gap:0.2rem;flex-wrap:wrap;margin-bottom:0.6rem;padding:0.5rem 0.5rem;
  background:rgba(0,0,0,0.2);border:1px solid var(--line);border-radius:3px;}
.tp-step{display:flex;flex-direction:column;align-items:center;gap:0.15rem;flex-shrink:0;}
.tp-heb{font-family:var(--serif);font-size:1.5rem;line-height:1;}
.tp-glyph{font-size:0.95rem;line-height:1;opacity:0.85;}
.tp-glyph+.tp-glyph{font-size:0.7rem;opacity:0.55;margin-top:-0.1rem;}
.tp-label{font-family:var(--mono);font-size:0.36rem;color:var(--dim);}
body.glyph-mode .tp-label{display:none;}
body.english-mode .tp-glyph{opacity:0.3;}
.tp-arrow{font-family:var(--mono);font-size:0.55rem;color:var(--dim);
  align-self:center;padding:0 0.1rem;padding-top:0.5rem;}

/* Intelligence cycle bar */
.cycle-bar{display:flex;align-items:center;gap:0;
  padding:0.32rem 0.85rem;border-top:1px solid var(--line);
  background:rgba(8,8,16,0.88);flex-shrink:0;overflow-x:auto;scrollbar-width:none;
  justify-content:space-between;}
.cycle-bar::-webkit-scrollbar{display:none;}
.cycle-node{display:flex;flex-direction:column;align-items:center;
  gap:0.1rem;padding:0.18rem 0.35rem;border-radius:3px;
  transition:all 0.25s;opacity:0.28;cursor:default;position:relative;}
.cycle-node.active{opacity:1;}
.cycle-node.active .cn-glyph{text-shadow:0 0 8px currentColor;}
.cn-glyph{font-size:1.0rem;line-height:1;}
.cn-label{font-family:var(--mono);font-size:0.35rem;color:var(--dim);
  white-space:nowrap;letter-spacing:0.05em;}
body.glyph-mode .cn-label{display:none;}
.cycle-arrow{font-family:var(--mono);font-size:0.5rem;color:var(--dim);
  opacity:0.3;align-self:center;padding-bottom:0.4rem;}
.cycle-stats{font-family:var(--mono);font-size:0.42rem;color:var(--dim);
  display:flex;gap:0.5rem;align-items:center;padding-left:0.5rem;
  border-left:1px solid var(--line);flex-shrink:0;}
.cs-val{color:var(--gold);}

/* Loop indicators with glyphs */
.loop-ind{display:flex;align-items:center;gap:0.4rem;
  padding:0.5rem 0.6rem;background:rgba(255,255,255,0.02);
  border:1px solid var(--line);border-radius:3px;
  font-family:var(--mono);font-size:0.5rem;color:var(--dim);}
.loop-glyph{font-size:1.1rem;line-height:1;opacity:0.5;transition:opacity 0.3s;}
.loop-ind.loop-on .loop-glyph{opacity:1;}
.loop-ind.loop-on{border-color:rgba(74,138,90,0.4);color:var(--ink);}
.loop-ind.loop-warn{border-color:rgba(212,99,74,0.3);}

/* Mode toggle */
.mode-wrap{display:flex;margin-left:0.5rem;border:1px solid var(--line);border-radius:3px;overflow:hidden;}
.mb2{padding:0.18rem 0.45rem;background:transparent;color:var(--dim);
  font-family:var(--mono);font-size:0.46rem;cursor:pointer;
  border:none;transition:all 0.12s;}
.mb2.active{color:var(--gold);background:var(--gold-pale);}

/* ── ANALYSIS PANEL ── */
#panel-analysis{background:var(--bg2);overflow:hidden;}
.analysis-inner{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;
  padding:0.75rem;scrollbar-width:none;}
.analysis-inner::-webkit-scrollbar{display:none;}
.analysis-sec{margin-bottom:1rem;}
.a-title{font-family:var(--mono);font-size:0.5rem;letter-spacing:0.12em;
  color:var(--dim);text-transform:uppercase;margin-bottom:0.55rem;}
#fhcn-canvas{display:block;width:100%;max-width:340px;margin:0 auto;border-radius:3px;}

/* Loops */
.loops-g{display:grid;grid-template-columns:1fr 1fr;gap:0.4rem;}
.loop-ind{display:flex;align-items:center;gap:0.4rem;
  padding:0.5rem 0.6rem;background:rgba(255,255,255,0.02);
  border:1px solid var(--line);border-radius:3px;
  font-family:var(--mono);font-size:0.5rem;color:var(--dim);}
.loop-ind.full{grid-column:span 2;}
.ldot{width:7px;height:7px;border-radius:50%;background:var(--line);
  flex-shrink:0;transition:all 0.3s;}
.ldot.active{background:var(--emerge);box-shadow:0 0 6px var(--emerge);}
.ldot.warn{background:var(--ember);box-shadow:0 0 5px var(--ember);}
.ldot.running{background:var(--gold);animation:pulse 0.55s infinite;}

/* Traversal steps */
.ts{display:flex;align-items:flex-start;gap:0.5rem;
  padding:0.5rem 0.6rem;border-left:2px solid var(--line);
  margin-bottom:0.4rem;animation:fadeIn 0.2s ease;
  background:rgba(255,255,255,0.015);border-radius:0 3px 3px 0;}
.ts.primary{border-left-color:var(--gold-dim);}
.tsg{font-family:var(--serif);font-size:1.4rem;line-height:1;flex-shrink:0;}
.tsi{flex:1;min-width:0;}
.tsn{font-family:var(--mono);font-size:0.56rem;color:var(--ink);}
.tss{font-family:var(--mono);font-size:0.44rem;color:var(--dim);margin-top:0.12rem;}
.tsgate{font-family:var(--mono);font-size:0.42rem;color:var(--dim);font-style:italic;}

/* Atmosphere pills */
.sub-atm{display:flex;flex-wrap:wrap;gap:0.3rem;}
.sub-pill{font-family:var(--mono);font-size:0.44rem;padding:0.1rem 0.4rem;
  border-radius:10px;border:1px solid;letter-spacing:0.06em;}

/* Stats row */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:0.4rem;}
.stat-box{background:rgba(255,255,255,0.02);border:1px solid var(--line);
  border-radius:3px;padding:0.5rem 0.4rem;text-align:center;}
.stat-val{font-family:var(--mono);font-size:0.9rem;color:var(--gold);display:block;}
.stat-lbl{font-family:var(--mono);font-size:0.38rem;color:var(--dim);letter-spacing:0.08em;
  text-transform:uppercase;display:block;margin-top:0.1rem;}

/* Trav inline */
.trav-inline{font-family:var(--mono);font-size:0.5rem;color:var(--dim);
  word-break:break-all;padding:0.4rem 0.5rem;background:rgba(0,0,0,0.2);
  border:1px solid var(--line);border-radius:3px;line-height:1.7;}

/* Audit hash */
.audit-hash{font-family:var(--mono);font-size:0.44rem;color:var(--dim);
  word-break:break-all;padding:0.35rem 0.5rem;border:1px solid var(--line);
  border-radius:3px;background:rgba(0,0,0,0.25);}

/* ── BOTTOM NAV ── */
.bottom-nav{height:var(--nav-h);display:flex;border-top:1px solid var(--line);
  background:rgba(8,8,16,0.97);flex-shrink:0;
  padding-bottom:var(--safe-bottom);}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;
  justify-content:center;gap:0.2rem;cursor:pointer;
  border:none;background:transparent;color:var(--dim);
  font-family:var(--mono);font-size:0.42rem;letter-spacing:0.08em;
  text-transform:uppercase;transition:color 0.12s;padding:0.3rem 0;}
.nav-btn:active{background:var(--gold-pale);}
.nav-btn.active{color:var(--gold);}
.nav-icon{font-size:1.1rem;line-height:1;font-family:var(--serif);}
.nav-dot{width:4px;height:4px;border-radius:50%;background:var(--gold);
  opacity:0;transition:opacity 0.2s;margin-top:0.1rem;}
.nav-btn.active .nav-dot{opacity:1;}

/* ── QUICK STATS BAR (above chat input) ── */
.stats-bar{display:flex;gap:0.75rem;padding:0.28rem 0.85rem;
  border-top:1px solid var(--line);background:rgba(8,8,16,0.85);
  font-family:var(--mono);font-size:0.44rem;color:var(--dim);
  align-items:center;overflow-x:auto;scrollbar-width:none;flex-shrink:0;}
.stats-bar::-webkit-scrollbar{display:none;}
.sb-item{white-space:nowrap;display:flex;align-items:center;gap:0.25rem;}
.sb-val{color:var(--gold);}
.sb-sdot{width:5px;height:5px;border-radius:50%;background:var(--emerge);
  box-shadow:0 0 5px var(--emerge);animation:pulse 2s infinite;flex-shrink:0;}

/* ── ANIMATIONS ── */
@keyframes pulse{0%,100%{opacity:0.4;}50%{opacity:1;}}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px);}to{opacity:1;transform:none;}}
@keyframes emergeFlash{0%{opacity:0;transform:scale(0.9);}20%{opacity:1;transform:scale(1.03);}100%{opacity:1;transform:scale(1);}}

/* ── DESKTOP OVERRIDE — side-by-side layout ── */
@media (min-width: 768px) {
  .hdr{padding:0 1.5rem;}
  .main-area{display:grid!important;grid-template-columns:260px 1fr 280px;}
  .panel{position:relative!important;opacity:1!important;pointer-events:all!important;
    transform:none!important;inset:auto!important;}
  #panel-substrate{display:flex!important;border-right:1px solid var(--line);}
  #panel-chat{display:flex!important;order:2;}
  #panel-analysis{display:flex!important;border-left:1px solid var(--line);}
  .bottom-nav{display:none!important;}
  .depth-wrap{display:flex!important;}
  .stats-bar{display:none!important;}
  .cycle-bar{display:flex!important;}
  .chat-input-wrap{padding-bottom:0.6rem!important;}
  .sub-panel-inner{overflow-y:auto;}
  .analysis-inner{overflow-y:auto;}
  #fhcn-canvas{max-width:100%;}
}

/* ── BEDROCK PANEL ── */
#panel-bedrock{background:var(--bg);overflow:hidden;}
.bk-inner{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;
  padding:0.75rem;scrollbar-width:none;}
.bk-inner::-webkit-scrollbar{display:none;}
.bk-sec{margin-bottom:1.1rem;}
.bk-title{font-family:var(--mono);font-size:0.5rem;letter-spacing:0.14em;
  color:var(--dim);text-transform:uppercase;margin-bottom:0.55rem;
  display:flex;justify-content:space-between;align-items:center;}
.bk-title span{color:var(--gold);}

/* State vector bars */
.sv-row{display:flex;align-items:center;gap:0.55rem;margin-bottom:0.38rem;}
.sv-glyph{font-size:1.05rem;line-height:1;width:1.4rem;text-align:center;flex-shrink:0;}
.sv-label{font-family:var(--mono);font-size:0.44rem;color:var(--dim);width:3.5rem;flex-shrink:0;}
.sv-bar-wrap{flex:1;height:6px;background:rgba(255,255,255,0.04);
  border-radius:3px;overflow:hidden;border:1px solid var(--line);}
.sv-bar{height:100%;border-radius:3px;transition:width 0.4s ease;min-width:2px;}
.sv-val{font-family:var(--mono);font-size:0.44rem;color:var(--gold);
  width:2.8rem;text-align:right;flex-shrink:0;}

/* Formula display */
.formula-eq{font-family:var(--mono);font-size:0.5rem;color:var(--ink);
  padding:0.6rem 0.65rem;background:rgba(0,0,0,0.25);
  border:1px solid var(--line);border-radius:3px;line-height:2;
  margin-bottom:0.5rem;}
.formula-eq .fo{color:var(--gold);}
.formula-eq .fv{color:var(--water);}
.formula-eq .fn{color:var(--simple);}
.formula-eq .fc{color:var(--emerge);}
.formula-eq .fe{color:var(--dim);}

/* SMAEE Lobby */
.lobby-header{display:flex;align-items:center;justify-content:space-between;
  padding:0.5rem 0.6rem;background:rgba(200,169,110,0.04);
  border:1px solid var(--line);border-radius:3px;margin-bottom:0.5rem;}
.lobby-title{font-family:var(--mono);font-size:0.5rem;color:var(--gold);}
.lobby-count{font-family:var(--mono);font-size:0.44rem;color:var(--dim);}
.agent-card{border:1px solid var(--line);border-radius:3px;
  margin-bottom:0.4rem;overflow:hidden;transition:border-color 0.2s;}
.agent-card.seated{border-color:rgba(200,169,110,0.4);}
.agent-card.active-agent{border-color:var(--emerge);
  background:rgba(74,138,90,0.04);}
.agent-header{display:flex;align-items:center;gap:0.5rem;
  padding:0.5rem 0.6rem;cursor:pointer;}
.agent-glyph{font-size:1.2rem;flex-shrink:0;}
.agent-name{font-family:var(--mono);font-size:0.52rem;color:var(--ink);flex:1;}
.agent-status{font-family:var(--mono);font-size:0.4rem;
  padding:0.06rem 0.28rem;border-radius:2px;border:1px solid;}
.as-active{color:var(--emerge);border-color:var(--emerge);}
.as-seated{color:var(--gold);border-color:var(--gold-dim);}
.as-dormant{color:var(--dim);border-color:var(--line);}
.agent-body{padding:0 0.6rem 0.5rem;display:none;}
.agent-card.open .agent-body{display:block;}
.agent-obs{font-family:var(--serif);font-size:0.82rem;color:var(--ink);
  line-height:1.75;margin-bottom:0.4rem;}
.agent-sig{font-family:var(--mono);font-size:0.42rem;color:var(--dim);
  padding:0.22rem 0.38rem;background:rgba(0,0,0,0.2);
  border-radius:2px;border:1px solid var(--line);}
.agent-formula{font-family:var(--mono);font-size:0.44rem;color:var(--water);
  margin-top:0.3rem;padding:0.3rem 0.38rem;
  background:rgba(74,143,168,0.05);border-radius:2px;}

/* Stability meter */
.stability-row{display:flex;align-items:center;gap:0.6rem;
  padding:0.4rem 0.5rem;background:rgba(0,0,0,0.15);
  border-radius:3px;border:1px solid var(--line);}
.stab-label{font-family:var(--mono);font-size:0.44rem;color:var(--dim);white-space:nowrap;}
.stab-bar-wrap{flex:1;height:5px;background:rgba(255,255,255,0.04);
  border-radius:3px;overflow:hidden;}
.stab-bar{height:100%;border-radius:3px;transition:width 0.6s ease;background:var(--emerge);}
.stab-val{font-family:var(--mono);font-size:0.44rem;color:var(--gold);white-space:nowrap;}

/* Bedrock pulse animation */
@keyframes bedrockPulse{
  0%{box-shadow:0 0 0 0 rgba(200,169,110,0.4);}
  70%{box-shadow:0 0 0 6px rgba(200,169,110,0);}
  100%{box-shadow:0 0 0 0 rgba(200,169,110,0);}
}
.bk-active{animation:bedrockPulse 1.5s ease;}
</style>
</head>
<body>

<!-- HEADER -->
<div class="hdr">
  <div class="logo">Mashet</div>
  <div class="hdr-right">
    <div class="sdot"></div>
    <div class="hdr-status" id="sys-status">READY</div>
    <div class="mode-wrap">
      <button class="mb2" onclick="setMode('glyph')" id="mb-g" title="Glyph only">⨖</button>
      <button class="mb2 active" onclick="setMode('hybrid')" id="mb-h" title="Hybrid">≋</button>
      <button class="mb2" onclick="setMode('english')" id="mb-e" title="English">Aa</button>
    </div>
    <div class="depth-wrap">
      <button class="db active" onclick="setDepth(1)">L</button>
      <button class="db" onclick="setDepth(2)">W</button>
      <button class="db" onclick="setDepth(3)">P</button>
    </div>
  </div>
</div>

<!-- MAIN AREA -->
<div class="main-area">

  <!-- PANEL 1: CHAT -->
  <div class="panel active" id="panel-chat">
    <div class="chat-scroll" id="chat-scroll">
      <div class="msg system">
        <div class="mb">The substrate is listening. Transmit a question, a concept, a fragment of thought — the letters will locate what is already moving in your words and speak from inside that territory. Nothing here is retrieved. Everything is traversed.</div>
        <div class="mt">DEPTH: Letter · LOOPS: 5 · GENESIS: #msht-2026 · DOMAINS: Hebrew · Math · Indus</div>
      </div>
    </div>
    <!-- Intelligence cycle bar — replaces plain stats bar -->
    <div class="cycle-bar" id="cycle-bar">
      <div class="cycle-node" id="cy-0" title="Internal Dynamics / State Core">
        <span class="cn-glyph" style="color:var(--gold)">☉</span>
        <span class="cn-label">STATE</span>
      </div>
      <span class="cycle-arrow">→</span>
      <div class="cycle-node" id="cy-1" title="Recursion / Iteration">
        <span class="cn-glyph" style="color:var(--simple)">⟲</span>
        <span class="cn-label">RECURSE</span>
      </div>
      <span class="cycle-arrow">→</span>
      <div class="cycle-node" id="cy-2" title="Memory / Integral Accumulation">
        <span class="cn-glyph" style="color:var(--water)">∫↺</span>
        <span class="cn-label">MEMORY</span>
      </div>
      <span class="cycle-arrow">→</span>
      <div class="cycle-node" id="cy-3" title="Coupling / Network">
        <span class="cn-glyph" style="color:var(--ember)">⧖</span>
        <span class="cn-label">COUPLE</span>
      </div>
      <span class="cycle-arrow">→</span>
      <div class="cycle-node" id="cy-4" title="Evaluation / Fitness">
        <span class="cn-glyph" style="color:var(--gold)">⚖</span>
        <span class="cn-label">EVAL</span>
      </div>
      <span class="cycle-arrow">→</span>
      <div class="cycle-node" id="cy-5" title="Noise / Stochasticity">
        <span class="cn-glyph" style="color:var(--dim)">≋</span>
        <span class="cn-label">NOISE</span>
      </div>
      <span class="cycle-arrow">→</span>
      <div class="cycle-node" id="cy-6" title="Unified State / Resolve">
        <span class="cn-glyph" style="color:var(--emerge)">⨖</span>
        <span class="cn-label">RESOLVE</span>
      </div>
      <!-- hidden stat sources — keep IDs for JS references -->
      <div class="cycle-stats">
        <span>G:<span class="cs-val" id="stat-gates">0</span></span>
        <span>M:<span class="cs-val" id="stat-myelin">0</span></span>
        <span>E:<span class="cs-val" id="stat-emerged">0</span></span>
        <span>T:<span class="cs-val" id="stat-turns">0</span></span>
      </div>
    </div>
    <!-- keep sb-status id for JS, hidden -->
    <span id="sb-status" style="display:none">READY</span>
    <span id="sb-depth-label" style="display:none">LETTER DEPTH</span>
    <div class="chat-input-wrap">
      <div class="chat-input-row">
        <input type="text" id="chat-in"
          placeholder="Transmit intent to the substrate..."
          onkeydown="if(event.key==='Enter'&&!event.shiftKey)transmit()"
          autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false">
        <button id="send-btn" onclick="transmit()">RESONATE</button>
      </div>
    </div>
  </div>

  <!-- PANEL 2: SUBSTRATE (Alphabet + Gates) -->
  <div class="panel" id="panel-substrate">
    <div class="sub-panel-inner">
      <div class="alpha-section">
        <div class="alpha-sec-title">Hebrew Substrate · 22 Letters</div>
        <div class="alpha-grid" id="grid-top"></div>
        <div class="alpha-grid" id="grid-bot"></div>
      </div>
      <div class="gate-section">
        <div class="gp-title">
          <span id="gate-title">AVAILABLE GATES</span>
          <span id="gate-count" style="color:var(--gold)"></span>
        </div>
        <div id="gate-list">
          <div class="no-gates">Transmit a message to activate gates</div>
        </div>
      </div>
    </div>
  </div>

  <!-- PANEL 3: ANALYSIS -->
  <div class="panel" id="panel-analysis">
    <div class="analysis-inner">

      <div class="analysis-sec">
        <div class="a-title">☉ → ⟲ → ∫↺ → ⧖ → ⚖ → ≋ → ⨖</div>
        <div class="stats-row">
          <div class="stat-box"><span class="stat-val" id="a-gates">0</span><span class="stat-lbl">⧖ Gates</span></div>
          <div class="stat-box"><span class="stat-val" id="a-myelin">0</span><span class="stat-lbl">∫↺ Myelin</span></div>
          <div class="stat-box"><span class="stat-val" id="a-emerged">0</span><span class="stat-lbl">⨏ Emerged</span></div>
          <div class="stat-box"><span class="stat-val" id="a-turns">0</span><span class="stat-lbl">⟲ Turns</span></div>
        </div>
      </div>

      <div class="analysis-sec">
        <div class="a-title" id="fhcn-title">FHCN · Spherical Distribution</div>
        <canvas id="fhcn-canvas" height="180"></canvas>
      </div>

      <div class="analysis-sec">
        <div class="a-title">Feedback Loops</div>
        <div class="loops-g">
          <div class="loop-ind" id="li1"><span class="loop-glyph" style="color:var(--simple)">⌖</span><div class="ldot" id="l1"></div><span>L1 Validate</span></div>
          <div class="loop-ind" id="li2"><span class="loop-glyph" style="color:var(--gold)">☉</span><div class="ldot" id="l2"></div><span>L2 Runtime</span></div>
          <div class="loop-ind" id="li3"><span class="loop-glyph" style="color:var(--water)">∫↺</span><div class="ldot" id="l3"></div><span>L3 Analysis</span></div>
          <div class="loop-ind" id="li4"><span class="loop-glyph" style="color:var(--simple)">⟲</span><div class="ldot" id="l4"></div><span>L4 Expand</span></div>
          <div class="loop-ind full" id="li5"><span class="loop-glyph" style="color:var(--emerge)">⨖</span><div class="ldot" id="l5"></div><span>L5 Audit Chain</span></div>
        </div>
      </div>

      <div class="analysis-sec">
        <div class="a-title">Active Traversal</div>
        <div class="trav-inline" id="trav-inline">—</div>
        <div id="trav-steps" style="margin-top:0.5rem"></div>
      </div>

      <div class="analysis-sec">
        <div class="a-title">Substrate Atmosphere</div>
        <div class="sub-atm" id="sub-atm">
          <span style="color:var(--dim);font-size:0.5rem;font-family:var(--mono)">—</span>
        </div>
      </div>

      <div class="analysis-sec">
        <div class="a-title">Audit Hash</div>
        <div class="audit-hash" id="audit-hash">MASHET-GENESIS-2026</div>
      </div>

      <div class="analysis-sec" id="pattern-sec" style="display:none">
        <div class="a-title">⨏ Emergent Patterns</div>
        <div id="pattern-list" style="display:flex;flex-direction:column;gap:0.3rem"></div>
      </div>

    </div>
  </div>

</div>

<!-- BOTTOM NAV (mobile only) -->
<!-- BEDROCK PANEL -->
<div class="panel" id="panel-bedrock">
  <div class="bk-inner">

    <!-- State Vector -->
    <div class="bk-sec">
      <div class="bk-title">Bedrock State Vector S<span id="bk-cycle">₀</span></div>
      <div id="sv-rows"></div>
    </div>

    <!-- Core Formula live -->
    <div class="bk-sec">
      <div class="bk-title">Core Formula</div>
      <div class="formula-eq" id="formula-display">
        <span class="fo">S</span><span class="fe">ₖ</span> = 
        <span class="fn">A</span> + 
        <span class="fo">F</span>(<span class="fv">S</span><span class="fe">ₖ₋₁</span>) + 
        <span class="fc">∫C(τ)dτ</span> + 
        <span class="fv">feedback</span>(<span class="fv">S</span>) + 
        <span class="fe">ε</span>
      </div>
      <div class="formula-eq" id="formula-live" style="font-size:0.44rem;color:var(--dim);">
        Awaiting first traversal...
      </div>
    </div>

    <!-- Stability -->
    <div class="bk-sec">
      <div class="bk-title">System Stability</div>
      <div class="stability-row">
        <span class="stab-label">⌖ Stability</span>
        <div class="stab-bar-wrap"><div class="stab-bar" id="stab-bar" style="width:0%"></div></div>
        <span class="stab-val" id="stab-val">—</span>
      </div>
    </div>

    <!-- SMAEE Lobby -->
    <div class="bk-sec">
      <div class="bk-title">SMAEE Lobby <span id="lobby-agent-count">1 agent seated</span></div>
      <div class="lobby-header">
        <span class="lobby-title">⨖ Agent Registry</span>
        <span class="lobby-count" id="lobby-status">LOBBY OPEN</span>
      </div>
      <div id="agent-registry"></div>
    </div>

    <!-- Mashet Symbol Substrate -->
    <div class="bk-sec">
      <div class="bk-title">Symbol Substrate <span>active glyphs</span></div>
      <div id="glyph-substrate-display" style="font-family:var(--serif);font-size:1.4rem;
        line-height:2;letter-spacing:0.3rem;color:var(--dim);
        padding:0.5rem;border:1px solid var(--line);border-radius:3px;
        background:rgba(0,0,0,0.15);word-break:break-all;"></div>
    </div>

    <!-- Variant Kernel Layer + TIS -->
    <div class="bk-sec">
      <div class="bk-title">Variant Kernel Layer <span id="variant-count">0 variants</span></div>
      <div id="variant-layer" style="font-family:var(--mono);font-size:0.44rem;
        color:var(--dim);padding:0.4rem 0.5rem;"></div>
    </div>

    <!-- ARV + Metaphysical Interface + APDAC -->
    <div class="bk-sec">
      <div class="bk-title">⧬ ARV · Metaphysical Interface <span id="arv-state">inactive</span></div>
      <div id="arv-display" style="padding:0.4rem 0.5rem;border:1px solid var(--line);
        border-radius:3px;background:rgba(74,143,168,0.03);">
        <div style="font-family:var(--mono);font-size:0.42rem;color:var(--dim)">
          Waiting for substrate superimposition...
        </div>
      </div>
    </div>

    <!-- Indus Address -->
    <div class="bk-sec">
      <div class="bk-title">Indus Address · Current Coordinate</div>
      <div id="indus-address" style="font-family:var(--mono);font-size:0.44rem;
        color:var(--dim);padding:0.4rem 0.5rem;border:1px solid var(--line);
        border-radius:3px;background:rgba(0,0,0,0.15);">
        No address computed yet
      </div>
    </div>

  </div>
</div>

<div class="bottom-nav">
  <button class="nav-btn active" id="nav-chat" onclick="switchPanel('chat')">
    <span class="nav-icon">פ</span>
    <span>Chat</span>
    <div class="nav-dot"></div>
  </button>
  <button class="nav-btn" id="nav-substrate" onclick="switchPanel('substrate')">
    <span class="nav-icon">א</span>
    <span>Substrate</span>
    <div class="nav-dot"></div>
  </button>
  <button class="nav-btn" id="nav-analysis" onclick="switchPanel('analysis')">
    <span class="nav-icon">☉</span>
