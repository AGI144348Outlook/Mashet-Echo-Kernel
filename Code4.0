// ═══════════════════════════════════════════════════════
// COMPOSITION GRAMMAR
// 5 fundamental modes: Sequential(→), Parallel(⊕),
// Nested(A(B)), Feedback(↺), Conditional(Λ)
// Precedence: Nested > Feedback > Sequential > Parallel > Conditional
// ═══════════════════════════════════════════════════════
const COMP_MODES = {
  sequential: { sym:'→', title:'Sequential: ordered execution — B(A(S))' },
  parallel:   { sym:'⊕', title:'Parallel: simultaneous — A(S)+B(S)' },
  nested:     { sym:'()', title:'Nested: A governs B — A(B(S))' },
  feedback:   { sym:'↺', title:'Feedback: loop until convergence' },
  conditional:{ sym:'Λ', title:'Conditional: gated execution' }
};

// ═══════════════════════════════════════════════════════
// CANONICAL COMPOSITION PATTERNS
// Named patterns that recur → candidates for new glyphs
// ═══════════════════════════════════════════════════════
const CANON_PATTERNS = [
  { seq:['gem','gem'],        sym:'⟲↺',  name:'Expansion Loop',            desc:'pure recursive growth' },
  { seq:['gem','assoc'],      sym:'(⟲⊕∫↺)', name:'Memory-Stabilized Recursion', desc:'prevents runaway recursion' },
  { seq:['assoc','sy'],       sym:'∫↺⊕⧖', name:'Relational Memory Field',   desc:'memory + structure → semantic network' },
  { seq:['root','assoc','gem'], sym:'⬡→∫↺→⟲', name:'Rooted Expansion',      desc:'anchor → recall → recurse' },
  { seq:['assoc','sy','assoc','gem'], sym:'⧉', name:'Deep Coupling',          desc:'high-order compound: memory-couple-recurse' },
  { seq:['gem','sy','glyph'], sym:'⟲→⧖→⚙', name:'Evaluated Expansion',       desc:'generate → couple → execute' }
];

// Track gate sequence frequency for emergent pattern detection
const patternFrequency = {};  // "assoc→gem" → count
const emergentPatterns = {};  // detected compound operators

function recordGateSequence(traversal){
  if(traversal.length < 2) return;
  const gateSeq = traversal.slice(1).map(s => s.gateType).filter(Boolean);
  if(!gateSeq.length) return;
  // Record pairs and triples
  for(let i=0; i<gateSeq.length; i++){
    const pair = gateSeq.slice(i, i+2).join('→');
    const triple = gateSeq.slice(i, i+3).join('→');
    patternFrequency[pair] = (patternFrequency[pair]||0) + 1;
    if(triple.split('→').length > 2)
      patternFrequency[triple] = (patternFrequency[triple]||0) + 1;
  }
  // Check if any canonical pattern is now frequent
  CANON_PATTERNS.forEach(p => {
    const key = p.seq.join('→');
    if((patternFrequency[key]||0) >= 3 && !emergentPatterns[key]){
      emergentPatterns[key] = p;
    }
  });
}

function detectComposition(traversal){
  // Given a traversal path, identify which composition pattern it matches
  const gates = traversal.slice(1).map(s => s.gateType).filter(Boolean);
  if(!gates.length) return null;
  const key = gates.join('→');
  // Check canonical patterns first
  for(const p of CANON_PATTERNS){
    if(p.seq.join('→') === key || key.includes(p.seq.join('→'))){
      return p;
    }
  }
  // Check emergent patterns
  if(emergentPatterns[key]) return emergentPatterns[key];
  return null;
}

function buildGlyphEquation(traversal){
  // Renders traversal as a glyph equation string
  // e.g. ⌑ → ∫↺ → ⟲ → ⧖ → ⚙ → ⨖
  const steps = traversal.map((step, i) => {
    const gg = step.gateType ? GATE_GLYPHS[step.gateType] : null;
    const letterGlyph = L[step.idx].g;
    if(i === 0) return `☉(${letterGlyph})`;
    return gg ? `${gg.sym}(${letterGlyph})` : letterGlyph;
  });
  return steps.join(' → ') + ' → ⨖';
}

