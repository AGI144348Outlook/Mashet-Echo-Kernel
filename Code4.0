// INTELLIGENCE CYCLE — ☉→⟲→∫↺→⧖→⚖→≋→⨖
// Phases map to gate types via loop_phase index
// ═══════════════════════════════════════════════════════
const CYCLE_PHASES = [
  { id:'cy-0', sym:'☉',  phase:'root',     color:'var(--gold)',   title:'Root / Anchor / Initialize' },
  { id:'cy-1', sym:'⟲',  phase:'gem',      color:'var(--simple)', title:'Gem / Recursive Expansion' },
